@inherits LayoutComponentBase

<div class="page">
    <header class="topbar">
        <a class="brand" href="/">TürevRent</a>
        <AuthorizeView>
            <Authorized>
                <nav class="nav">
                    <a href="/">Panel</a>
                    @* Operasyon (OperationsWrite: Admin/Yönetici/Operatör) *@
                    <AuthorizeView Roles="Admin,Yonetici,Operator" Context="opCtx">
                        <a href="/vehicles">Araçlar</a>
                        <a href="/cariler">Cariler</a>
                        <a href="/musaitlik">Müsaitlik</a>
                        <a href="/teklifler">Teklifler</a>
                        <a href="/rezervasyonlar">Rezervasyonlar</a>
                        <a href="/takvim">Takvim</a>
                        <a href="/kiralar">Kiralar</a>
                        <a href="/hasar">Hasar</a>
                        <a href="/servisler">Servis</a>
                        <a href="/regulasyon">Sigorta/MTV</a>
                        <a href="/tarifeler">Tarifeler</a>
                        <a href="/lokasyonlar">Lokasyonlar</a>
                        <a href="/yakit-turleri">Yakıt Türleri</a>
                        <a href="/vites-turleri">Vites Türleri</a>
                        <a href="/renkler">Renkler</a>
                        <a href="/musteri-gruplari">Müşteri Grupları</a>
                        <a href="/sigorta-sirketleri">Sigorta Şirketleri</a>
                        <a href="/bankalar">Bankalar</a>
                        <a href="/departmanlar">Departmanlar</a>
                        <a href="/odeme-tipleri">Ödeme Tipleri</a>
                        <a href="/ulkeler">Ülkeler</a>
                        <a href="/iptal-sebepleri">İptal Sebepleri</a>
                        <a href="/rezervasyon-kaynaklari">Rez. Kaynakları</a>
                        <a href="/segmentler">Segmentler</a>
                        <a href="/arac-tipleri">Araç Tipleri</a>
                        <a href="/arac-sahipleri">Araç Sahipleri</a>
                        <a href="/gider-turleri">Gider Türleri</a>
                        <a href="/hesaplar">Hesaplar</a>
                        <a href="/ozel-kodlar">Özel Kodlar</a>
                    </AuthorizeView>
                    @* Finans (FinanceWrite: Admin/Yönetici/Muhasebe) *@
                    <AuthorizeView Roles="Admin,Yonetici,Muhasebe" Context="finCtx">
                        <a href="/kasa">Kasa</a>
                        <a href="/giderler">Giderler</a>
                        <a href="/satislar">Satışlar</a>
                        <a href="/faturalar">Faturalar</a>
                    </AuthorizeView>
                    <a href="/cezalar">Cezalar</a>
                    @* Raporlar (ViewReports: Admin/Yönetici/Muhasebe) *@
                    <AuthorizeView Roles="Admin,Yonetici,Muhasebe" Context="repCtx">
                        <a href="/raporlar/gelir-gider">Raporlar</a>
                        <a href="/raporlar/cari-bakiye">Cari Bakiye</a>
                        <a href="/raporlar/filo">Filo</a>
                        <a href="/raporlar/doluluk">Doluluk</a>
                        <a href="/raporlar/tahsilat-fatura">Tahsilat-Fatura</a>
                    </AuthorizeView>
                    <a href="/vade">Vade</a>
                    <AuthorizeView Roles="Admin" Context="adminCtx">
                        <a href="/subeler">Şubeler</a>
                        <a href="/kullanicilar">Kullanıcılar</a>
                        <a href="/denetim">Denetim</a>
                    </AuthorizeView>
                </nav>
                <span class="spacer"></span>
                <span class="user">
                    @context.User.Identity?.Name
                    <span class="muted">@context.User.FindFirst("tenant_code")?.Value</span>
                </span>
                <form method="post" action="/auth/logout" class="logout-form">
                    <button type="submit" class="link">Çıkış</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <span class="spacer"></span>
                <a href="/login">Giriş</a>
            </NotAuthorized>
        </AuthorizeView>
    </header>

    <main class="content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Beklenmeyen bir hata oluştu.
    <a href="." class="reload">Yenile</a>
    <span class="dismiss">🗙</span>
</div>
