@page "/giderler"
@attribute [Authorize]
@inject ExpenseService Expenses
@inject VehicleService Vehicles
@inject CustomerService Customers

<PageTitle>Giderler — TürevRent</PageTitle>

<h1>Giderler</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Gider</summary>
    <form method="post" action="/giderler/create" class="grid-form"><AntiforgeryToken />
        <label>Tür
            <select name="tip">
                @foreach (var t in Enum.GetValues<ExpenseType>())
                {
                    <option value="@t">@t</option>
                }
            </select>
        </label>
        <label>Araç
            <select name="vehicleId">
                <option value="">—</option>
                @foreach (var v in _vehicles)
                {
                    <option value="@v.Id">@v.Plaka</option>
                }
            </select>
        </label>
        <label>Tedarikçi
            <select name="cariId">
                <option value="">—</option>
                @foreach (var c in _customers)
                {
                    <option value="@c.Id">@c.DisplayName</option>
                }
            </select>
        </label>
        <label>Net Tutar<input name="netTutar" type="number" step="0.01" required /></label>
        <label>KDV Oranı<input name="kdvOrani" type="number" step="0.01" value="0.20" /></label>
        <label>Ödeme
            <select name="odemeYontemi">
                @foreach (var o in Enum.GetValues<OdemeYontemi>())
                {
                    <option value="@o">@o</option>
                }
            </select>
        </label>
        <label>Döviz<select name="doviz"><option>TRY</option><option>USD</option><option>EUR</option></select></label>
        <label>Kur<input name="kur" type="number" step="0.0001" value="1" /></label>
        <label>Evrak No<input name="evrakNo" /></label>
        <label>Açıklama<input name="aciklama" /></label>
        <button type="submit">Kaydet</button>
    </form>
</details>

<table class="grid">
    <thead>
        <tr><th>No</th><th>Tür</th><th>Tarih</th><th>Araç/Tedarikçi</th><th>Net</th><th>KDV</th><th>Toplam</th><th>Ödeme</th></tr>
    </thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="8" class="muted">Gider yok.</td></tr>
        }
        @foreach (var e in _list)
        {
            <tr>
                <td>@e.No</td>
                <td>@e.Tip</td>
                <td>@e.Tarih.LocalDateTime.ToString("dd.MM.yyyy")</td>
                <td>@RefLabel(e)</td>
                <td>@e.NetTutar.ToString("N2")</td>
                <td>@e.KdvTutar.ToString("N2")</td>
                <td>@e.GenelToplam.ToString("N2")</td>
                <td>@e.OdemeYontemi</td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<Expense> _list = [];
    private IReadOnlyList<Vehicle> _vehicles = [];
    private IReadOnlyList<Customer> _customers = [];
    private Dictionary<Guid, string> _vehMap = new();
    private Dictionary<Guid, string> _custMap = new();

    protected override async Task OnInitializedAsync()
    {
        _list = await Expenses.ListAsync();
        _vehicles = await Vehicles.ListAsync();
        _customers = await Customers.ListAsync();
        _vehMap = _vehicles.ToDictionary(v => v.Id, v => v.Plaka);
        _custMap = _customers.ToDictionary(c => c.Id, c => c.DisplayName);
    }

    private string RefLabel(Expense e)
    {
        if (e.VehicleId is Guid v && _vehMap.TryGetValue(v, out var p)) return p;
        if (e.CariId is Guid c && _custMap.TryGetValue(c, out var n)) return n;
        return "—";
    }
}
