@page "/sikayetler"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject SikayetService Sikayetler
@using RentACar.Domain.Enums

<PageTitle>Şikayetler — TürevRent</PageTitle>

<h1>Müşteri Şikayetleri</h1>
@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<table class="grid">
    <thead><tr><th>Tarih</th><th>Konu</th><th>Durum</th><th>Çözüm</th><th></th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="5" class="muted">Kayıt yok.</td></tr>
        }
        @foreach (var s in _list)
        {
            <tr>
                <td>@s.Tarih.ToString("yyyy-MM-dd")</td>
                <td>@s.Konu</td>
                <td>@s.Durum</td>
                <td>@s.Cozum</td>
                <td><a href="/sikayetler?duzenle=@s.Id">Düzenle</a></td>
            </tr>
        }
    </tbody>
</table>

<h2>@(_edit is null ? "Yeni Şikayet" : "Düzenle")</h2>
<form method="post" action="@(_edit is null ? "/sikayetler/create" : "/sikayetler/update")" class="grid-form"><AntiforgeryToken />
    @if (_edit is not null)
    {
        <input type="hidden" name="id" value="@_edit.Id" />
    }
    <label>Konu<input name="konu" value="@_edit?.Konu" required /></label>
    <label>Detay<input name="detay" value="@_edit?.Detay" /></label>
    <label>Durum
        <select name="durum">
            @foreach (var d in Enum.GetValues<SikayetDurum>())
            {
                <option value="@d" selected="@(_edit?.Durum == d)">@d</option>
            }
        </select></label>
    <label>Çözüm<input name="cozum" value="@_edit?.Cozum" /></label>
    <label>Cari ID (ops.)<input name="cariId" value="@_edit?.CariId" /></label>
    <label>Tarih<input name="tarih" type="date" value="@(_edit?.Tarih.ToString("yyyy-MM-dd"))" /></label>
    <button type="submit">@(_edit is null ? "Ekle" : "Kaydet")</button>
    @if (_edit is not null)
    {
        <a href="/sikayetler" class="btn-secondary">İptal</a>
    }
</form>

@if (_edit is not null)
{
    <form method="post" action="/sikayetler/delete" onsubmit="return confirm('Silinsin mi?');"><AntiforgeryToken />
        <input type="hidden" name="id" value="@_edit.Id" /><button type="submit" class="btn-danger">Sil</button>
    </form>
}

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }
    [SupplyParameterFromQuery(Name = "duzenle")] public Guid? Duzenle { get; set; }
    private IReadOnlyList<RentACar.Domain.Entities.Sikayet> _list = [];
    private RentACar.Domain.Entities.Sikayet? _edit;

    protected override async Task OnInitializedAsync()
    {
        _list = await Sikayetler.ListAsync();
        if (Duzenle is { } id) _edit = await Sikayetler.GetAsync(id);
    }
}
