@page "/ceza-turleri"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject PenaltyTypeService CezaTurleri

<PageTitle>Ceza Türleri — TürevRent</PageTitle>

<h1>Ceza Türü Tanımları</h1>
<p class="muted small">Trafik/park/HGS ihlali gibi ceza türlerinin sözlüğü. Ceza kayıt formundaki
    "Ceza Türü" açılır listesi buradan beslenir. Varsayılan tutar opsiyoneldir (form için öneri;
    ceza tutarı yine de serbest girilir).</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Ceza Türü</summary>
    <form method="post" action="/ceza-turleri/create" class="grid-form"><AntiforgeryToken />
        <label>Kod<input name="kod" required placeholder="HIZ" /></label>
        <label>Ad<input name="ad" required placeholder="Hız İhlali" /></label>
        <label>Varsayılan Tutar<input name="varsayilanTutar" type="number" step="0.01" min="0" placeholder="(opsiyonel)" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Varsayılan Tutar</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="5" class="muted">Ceza türü tanımlı değil.</td></tr>
        }
        @foreach (var t in _list)
        {
            <tr>
                <td class="mono">@t.Kod</td>
                <td>@t.Ad</td>
                <td class="num">@(t.VarsayilanTutar.HasValue ? t.VarsayilanTutar.Value.ToString("N2") : "—")</td>
                <td>@(t.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/ceza-turleri/update" class="grid-form"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@t.Id" />
                            <label>Kod<input name="kod" value="@t.Kod" required /></label>
                            <label>Ad<input name="ad" value="@t.Ad" required /></label>
                            <label>Varsayılan Tutar<input name="varsayilanTutar" type="number" step="0.01" min="0" value="@t.VarsayilanTutar" /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@t.Aktif">Aktif</option>
                                    <option value="false" selected="@(!t.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/ceza-turleri/delete" onsubmit="return confirm('Ceza türü silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@t.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<PenaltyType> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await CezaTurleri.ListAsync();
}
