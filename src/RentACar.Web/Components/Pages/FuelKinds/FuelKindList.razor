@page "/yakit-turleri"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject FuelKindService YakitTurleri

<PageTitle>Yakıt Türleri — TürevRent</PageTitle>

<h1>Yakıt Türü Tanımları</h1>
<p class="muted small">Araç yakıt tiplerinin sözlüğü (ör. "Benzin", "Dizel", "LPG", "Elektrik",
    "Hibrit"). Tanım/raporlama için.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Yakıt Türü</summary>
    <form method="post" action="/yakit-turleri/create" class="grid-form"><AntiforgeryToken />
        <label>Kod<input name="kod" required placeholder="DIZEL" /></label>
        <label>Ad<input name="ad" required placeholder="Dizel" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="4" class="muted">Yakıt türü tanımlı değil.</td></tr>
        }
        @foreach (var k in _list)
        {
            <tr>
                <td class="mono">@k.Kod</td>
                <td>@k.Ad</td>
                <td>@(k.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/yakit-turleri/update" class="grid-form"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@k.Id" />
                            <label>Kod<input name="kod" value="@k.Kod" required /></label>
                            <label>Ad<input name="ad" value="@k.Ad" required /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@k.Aktif">Aktif</option>
                                    <option value="false" selected="@(!k.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/yakit-turleri/delete" onsubmit="return confirm('Yakıt türü silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@k.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<FuelKind> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await YakitTurleri.ListAsync();
}
