@page "/raporlar/ek-hizmet"
@attribute [Authorize(Roles = "Admin,Yonetici,Muhasebe")]
@inject ReportService Reports

<PageTitle>Ek Hizmet Raporu — TürevRent</PageTitle>

<h1>Ek Hizmet Satış Raporu</h1>
<p class="muted small">📥 İndir:
    <a href="/raporlar/export/ek-hizmet?format=excel&amp;from=@From&amp;to=@To">Excel</a> ·
    <a href="/raporlar/export/ek-hizmet?format=csv&amp;from=@From&amp;to=@To">CSV</a></p>
<p class="muted small">Seçilen dönemde (kalem eklenme tarihi) İptal olmayan kiralara satılan ek
    hizmetlerin adına göre özeti. Tutarlar baz para (₺). Salt-okunur.</p>

<form method="get" class="filter-bar">
    <label>Başlangıç<input name="from" type="date" value="@From" /></label>
    <label>Bitiş<input name="to" type="date" value="@To" /></label>
    <button type="submit">Göster</button>
    @if (!string.IsNullOrEmpty(From) || !string.IsNullOrEmpty(To))
    {
        <a href="/raporlar/ek-hizmet" class="link">Temizle</a>
    }
</form>

<div class="cards">
    <div class="card">
        <div class="card-num">@_data.ToplamNet.ToString("N2")</div>
        <div class="card-label">Toplam Net ₺</div>
    </div>
    <div class="card">
        <div class="card-num">@_data.ToplamKdv.ToString("N2")</div>
        <div class="card-label">Toplam KDV ₺</div>
    </div>
    <div class="card">
        <div class="card-num">@_data.ToplamBrut.ToString("N2")</div>
        <div class="card-label">Genel Toplam ₺</div>
    </div>
    <div class="card">
        <div class="card-num">@_data.KiraAdet</div>
        <div class="card-label">Kira Adedi</div>
    </div>
</div>

<table class="grid">
    <thead>
        <tr><th>Ek Hizmet</th><th>Toplam Miktar</th><th>Kira Adedi</th><th>Net</th><th>KDV</th><th>Brüt</th></tr>
    </thead>
    <tbody>
        @if (_data.Satirlar.Count == 0)
        {
            <tr><td colspan="6" class="muted">Bu dönemde satılan ek hizmet yok.</td></tr>
        }
        @foreach (var s in _data.Satirlar)
        {
            <tr>
                <td>@s.Ad</td>
                <td class="num">@s.ToplamMiktar.ToString("0.##")</td>
                <td class="num">@s.KiraAdet</td>
                <td class="num">@s.Net.ToString("N2")</td>
                <td class="num">@s.Kdv.ToString("N2")</td>
                <td class="num">@s.Brut.ToString("N2")</td>
            </tr>
        }
    </tbody>
    @if (_data.Satirlar.Count > 0)
    {
        <tfoot>
            <tr>
                <th>Toplam</th>
                <th></th>
                <th class="num">@_data.KiraAdet</th>
                <th class="num">@_data.ToplamNet.ToString("N2")</th>
                <th class="num">@_data.ToplamKdv.ToString("N2")</th>
                <th class="num">@_data.ToplamBrut.ToString("N2")</th>
            </tr>
        </tfoot>
    }
</table>

@code {
    [SupplyParameterFromQuery(Name = "from")] public string? From { get; set; }
    [SupplyParameterFromQuery(Name = "to")] public string? To { get; set; }

    private EkHizmetRaporDto _data = new([], 0, 0, 0, 0);

    protected override async Task OnInitializedAsync()
    {
        var from = ParseDate(From);
        var to = ParseDate(To)?.AddDays(1).AddTicks(-1); // gün sonuna dek dahil
        _data = await Reports.GetEkHizmetRaporuAsync(from, to);
    }

    private static DateTimeOffset? ParseDate(string? s)
        => DateTimeOffset.TryParse(s, out var d) ? new DateTimeOffset(d.Date, TimeSpan.Zero) : null;
}
