@page "/hasar"
@attribute [Authorize]
@using RentACar.Domain.Enums
@inject DamageFileService Files
@inject VehicleService Vehicles
@inject CustomerService Customers

<PageTitle>Hasar Dosyaları (BAF) — TürevRent</PageTitle>

<h1>Hasar Dosyaları (BAF)</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Hasar Dosyası</summary>
    <form method="post" action="/hasar/create" class="grid-form"><AntiforgeryToken />
        <label>Araç
            <select name="vehicleId" required>
                <option value="">—</option>
                @foreach (var v in _vehicles)
                {
                    <option value="@v.Id">@v.Plaka</option>
                }
            </select>
        </label>
        <label>Sorumlu (Cari)
            <select name="cariId">
                <option value="">—</option>
                @foreach (var c in _customers)
                {
                    <option value="@c.Id">@c.DisplayName</option>
                }
            </select>
        </label>
        <label>Tahmini Tutar<input name="tahminiTutar" type="number" step="0.01" /></label>
        <label>Açıklama<input name="aciklama" /></label>
        <button type="submit">Aç</button>
    </form>
</details>

<table class="grid">
    <thead>
        <tr><th>No</th><th>Açılış</th><th>Araç</th><th>Sorumlu</th><th>Tahmini</th><th>Durum</th><th></th></tr>
    </thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="7" class="muted">Hasar dosyası yok.</td></tr>
        }
        @foreach (var f in _list)
        {
            <tr>
                <td>@f.No</td>
                <td>@f.AcilisTarihi.LocalDateTime.ToString("dd.MM.yyyy")</td>
                <td>@VehLabel(f.VehicleId)</td>
                <td>@CustLabel(f.CariId)</td>
                <td>@(f.TahminiTutar?.ToString("N2") ?? "—")</td>
                <td>@f.Durum</td>
                <td>
                    @if (f.Durum == HasarDurum.Acik)
                    {
                        <form method="post" action="/hasar/onaya-gonder" class="inline"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@f.Id" /><button type="submit">Onaya Gönder</button>
                        </form>
                    }
                    @if (f.Durum == HasarDurum.Onayda)
                    {
                        <form method="post" action="/hasar/onayla" class="inline"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@f.Id" /><button type="submit">Onayla</button>
                        </form>
                        <form method="post" action="/hasar/reddet" class="inline"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@f.Id" /><button type="submit">Reddet</button>
                        </form>
                    }
                    @if (f.Durum is HasarDurum.Onaylandi or HasarDurum.Reddedildi)
                    {
                        <form method="post" action="/hasar/kapat" class="inline"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@f.Id" /><button type="submit">Kapat</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<DamageFile> _list = [];
    private IReadOnlyList<Vehicle> _vehicles = [];
    private IReadOnlyList<Customer> _customers = [];
    private Dictionary<Guid, string> _vehMap = new();
    private Dictionary<Guid, string> _custMap = new();

    protected override async Task OnInitializedAsync()
    {
        _list = await Files.ListAsync();
        _vehicles = await Vehicles.ListAsync();
        _customers = await Customers.ListAsync();
        _vehMap = _vehicles.ToDictionary(v => v.Id, v => v.Plaka);
        _custMap = _customers.ToDictionary(c => c.Id, c => c.DisplayName);
    }

    private string VehLabel(Guid id) => _vehMap.TryGetValue(id, out var p) ? p : "—";
    private string CustLabel(Guid? id) => id is Guid c && _custMap.TryGetValue(c, out var n) ? n : "—";
}
