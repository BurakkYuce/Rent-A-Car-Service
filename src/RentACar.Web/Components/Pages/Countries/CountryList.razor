@page "/ulkeler"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject CountryService Ulkeler

<PageTitle>Ülkeler — TürevRent</PageTitle>

<h1>Ülke Tanımları</h1>
<p class="muted small">Ülkelerin sözlüğü (ör. "Türkiye", "Almanya", "ABD"). Cari/sürücü uyruğu ve
    adres formlarındaki Ülke açılır listesini besler.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Ülke</summary>
    <form method="post" action="/ulkeler/create" class="grid-form">
        <label>Kod<input name="kod" required placeholder="TR" /></label>
        <label>Ad<input name="ad" required placeholder="Türkiye" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="4" class="muted">Ülke tanımlı değil.</td></tr>
        }
        @foreach (var c in _list)
        {
            <tr>
                <td class="mono">@c.Kod</td>
                <td>@c.Ad</td>
                <td>@(c.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/ulkeler/update" class="grid-form">
                            <input type="hidden" name="id" value="@c.Id" />
                            <label>Kod<input name="kod" value="@c.Kod" required /></label>
                            <label>Ad<input name="ad" value="@c.Ad" required /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@c.Aktif">Aktif</option>
                                    <option value="false" selected="@(!c.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/ulkeler/delete" onsubmit="return confirm('Ülke silinsin mi?')">
                        <input type="hidden" name="id" value="@c.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<Country> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await Ulkeler.ListAsync();
}
