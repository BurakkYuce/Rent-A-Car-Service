@page "/subeler"
@attribute [Authorize(Roles = "Admin")]
@inject BranchService Branches

<PageTitle>Şubeler — TürevRent</PageTitle>

<h1>Şube Yönetimi</h1>
<p class="muted small">Yönetilen şube sözlüğü. Şube adları araç/gider/kullanıcı formlarında
    açılır liste kaynağı olarak kullanılır. (Mevcut serbest-metin şube alanları korunur.)</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Şube</summary>
    <form method="post" action="/subeler/create" class="grid-form"><AntiforgeryToken />
        <label>Kod<input name="kod" required placeholder="MERKEZ" /></label>
        <label>Ad<input name="ad" required placeholder="Merkez Ofis" /></label>
        <label>Adres<input name="adres" /></label>
        <label>Telefon<input name="telefon" /></label>
        <label>E-posta<input name="eposta" type="email" /></label>
        <label>İl<input name="il" /></label>
        <label>İlçe<input name="ilce" /></label>
        <label>Yetkili<input name="yetkili" /></label>
        <label>Çalışma Saatleri<input name="calismaSaatleri" placeholder="09:00-18:00" /></label>
        <label>Komisyon Oranı<input name="komisyonOran" type="number" step="0.0001" min="0" max="1" placeholder="0.10" /></label>
        <label>Evrak No Öneki<input name="evrakNoOnek" placeholder="MRK-" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>İl/İlçe</th><th>Yetkili</th><th>Telefon</th><th>Komisyon</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="8" class="muted">Şube tanımlı değil.</td></tr>
        }
        @foreach (var s in _list)
        {
            <tr>
                <td class="mono">@s.Kod</td>
                <td>@s.Ad</td>
                <td>@s.Il@(string.IsNullOrEmpty(s.Ilce) ? "" : " / " + s.Ilce)</td>
                <td>@s.Yetkili</td>
                <td>@s.Telefon</td>
                <td>@(s.KomisyonOran.HasValue ? s.KomisyonOran.Value.ToString("P2") : "")</td>
                <td>@(s.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/subeler/update" class="grid-form"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@s.Id" />
                            <label>Kod<input name="kod" value="@s.Kod" required /></label>
                            <label>Ad<input name="ad" value="@s.Ad" required /></label>
                            <label>Adres<input name="adres" value="@s.Adres" /></label>
                            <label>Telefon<input name="telefon" value="@s.Telefon" /></label>
                            <label>E-posta<input name="eposta" type="email" value="@s.Eposta" /></label>
                            <label>İl<input name="il" value="@s.Il" /></label>
                            <label>İlçe<input name="ilce" value="@s.Ilce" /></label>
                            <label>Yetkili<input name="yetkili" value="@s.Yetkili" /></label>
                            <label>Çalışma Saatleri<input name="calismaSaatleri" value="@s.CalismaSaatleri" /></label>
                            <label>Komisyon Oranı<input name="komisyonOran" type="number" step="0.0001" min="0" max="1" value="@s.KomisyonOran" /></label>
                            <label>Evrak No Öneki<input name="evrakNoOnek" value="@s.EvrakNoOnek" /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@s.Aktif">Aktif</option>
                                    <option value="false" selected="@(!s.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/subeler/delete" onsubmit="return confirm('Şube silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@s.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<Branch> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await Branches.ListAsync();
}
