@page "/ek-hizmetler"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject EkHizmetTanimService EkHizmetler

<PageTitle>Ek Hizmetler — TürevRent</PageTitle>

<h1>Ek Hizmet Tanımları</h1>
<p class="muted small">Kiraya eklenebilen fiyatlı opsiyonlar (bebek koltuğu, GPS, ek sürücü, kasko
    muafiyeti…). Kira ek hizmet kalemleri varsayılan birim ücret + KDV oranını buradan alır; kira
    formunda serbest fiyat da girilebilir. KDV oranı 0..1 (ör. 0.20 = %20).</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Ek Hizmet</summary>
    <form method="post" action="/ek-hizmetler/create" class="grid-form">
        <label>Kod<input name="kod" required placeholder="GPS" /></label>
        <label>Ad<input name="ad" required placeholder="Navigasyon" /></label>
        <label>Birim Ücret (NET)<input name="birimUcret" type="number" step="0.01" min="0" value="0" /></label>
        <label>KDV Oranı<input name="kdvOrani" type="number" step="0.01" min="0" max="1" value="0.20" placeholder="0.20 = %20" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Birim Ücret</th><th>KDV</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="6" class="muted">Ek hizmet tanımlı değil.</td></tr>
        }
        @foreach (var e in _list)
        {
            <tr>
                <td class="mono">@e.Kod</td>
                <td>@e.Ad</td>
                <td class="num">@e.BirimUcret.ToString("N2")</td>
                <td class="num">@($"%{e.KdvOrani * 100:0.##}")</td>
                <td>@(e.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/ek-hizmetler/update" class="grid-form">
                            <input type="hidden" name="id" value="@e.Id" />
                            <label>Kod<input name="kod" value="@e.Kod" required /></label>
                            <label>Ad<input name="ad" value="@e.Ad" required /></label>
                            <label>Birim Ücret (NET)<input name="birimUcret" type="number" step="0.01" min="0" value="@e.BirimUcret" /></label>
                            <label>KDV Oranı<input name="kdvOrani" type="number" step="0.01" min="0" max="1" value="@e.KdvOrani" /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@e.Aktif">Aktif</option>
                                    <option value="false" selected="@(!e.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/ek-hizmetler/delete" onsubmit="return confirm('Ek hizmet silinsin mi?')">
                        <input type="hidden" name="id" value="@e.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<EkHizmetTanim> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await EkHizmetler.ListAsync();
}
