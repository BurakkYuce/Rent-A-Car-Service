@page "/cariler"
@attribute [Authorize]
@inject CustomerService Customers

<PageTitle>Cariler — TürevRent</PageTitle>

<h1>Cariler</h1>
<p class="muted small">İndir: <a href="/listeler/export/cariler">Excel</a> · <a href="/listeler/export/cariler?format=csv">CSV</a></p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_page.Total == 0)">
    <summary>+ Yeni Cari</summary>
    <form method="post" action="/cariler/create" class="grid-form"><AntiforgeryToken />
        <label>Tür
            <select name="tip">
                @foreach (var t in Enum.GetValues<CariType>())
                {
                    <option value="@t">@t</option>
                }
            </select>
        </label>
        <label>Ad<input name="ad" /></label>
        <label>Soyad<input name="soyad" /></label>
        <label>TC Kimlik<input name="tcKimlik" maxlength="11" /></label>
        <label>Ünvan<input name="unvan" /></label>
        <label>Vergi Dairesi<input name="vergiDairesi" /></label>
        <label>Vergi No<input name="vergiNo" maxlength="10" /></label>
        <label>Cep Tel<input name="cepTel" /></label>
        <label>E-posta<input name="email" type="email" /></label>
        <label>İl<input name="il" /></label>
        <label>İlçe<input name="ilce" /></label>
        <label>Tarife<input name="tarife" /></label>
        <label>Vade (gün)<input name="vadeGun" type="number" value="0" /></label>
        <label>Risk Limiti<input name="riskLimiti" type="number" step="0.01" value="0" /></label>
        <label>Kara Liste
            <select name="karaListe"><option value="false">Hayır</option><option value="true">Evet</option></select>
        </label>
        <label>Pasif
            <select name="pasif"><option value="false">Hayır</option><option value="true">Evet</option></select>
        </label>
        <button type="submit">Kaydet</button>
    </form>
</details>

<form method="get" class="filter-bar">
    <input name="q" value="@Q" placeholder="Ad / ünvan / TC / vergi no ara" />
    <select name="tip">
        <option value="">Tür (tümü)</option>
        @foreach (var t in Enum.GetValues<CariType>())
        {
            <option value="@t" selected="@(Tip == t.ToString())">@t</option>
        }
    </select>
    <select name="iys">
        <option value="">İYS (tümü)</option>
        <option value="true" selected="@(Iys == "true")">İzinli</option>
        <option value="false" selected="@(Iys == "false")">İzinsiz</option>
    </select>
    <select name="uyari">
        <option value="">Uyarı (tümü)</option>
        <option value="true" selected="@(UyariF == "true")">Uyarılı</option>
    </select>
    <select name="kara">
        <option value="">Kara Liste (tümü)</option>
        <option value="true" selected="@(Kara == "true")">Kara listede</option>
    </select>
    <button type="submit">Filtrele</button>
    @if (!string.IsNullOrEmpty(Q) || !string.IsNullOrEmpty(Tip) || !string.IsNullOrEmpty(Iys) || !string.IsNullOrEmpty(UyariF) || !string.IsNullOrEmpty(Kara))
    {
        <a href="/cariler" class="link">Temizle</a>
    }
</form>

<table class="grid">
    <thead>
        <tr>
            <th>Tür</th><th>Ad / Ünvan</th><th>TC / Vergi No</th><th>Telefon</th>
            <th>Kaynak</th><th>Kira</th><th>Ciro</th><th>Son Kira</th><th>Durum</th><th></th>
        </tr>
    </thead>
    <tbody>
        @if (_page.Items.Count == 0)
        {
            <tr><td colspan="10" class="muted">Kayıtlı cari yok.</td></tr>
        }
        @foreach (var c in _page.Items)
        {
            <tr>
                <td>@c.Tip</td>
                <td><a href="/cariler/@c.Id">@c.DisplayName</a></td>
                <td>@(c.Tip == CariType.Bireysel ? c.TcKimlik : c.VergiNo)</td>
                <td>@c.CepTel</td>
                <td>@c.Kaynak</td>
                <td class="num">@c.KiraAdet</td>
                <td class="num">@c.Ciro.ToString("N2")</td>
                <td>@(c.SonKira?.LocalDateTime.ToString("dd.MM.yyyy") ?? "—")</td>
                <td>
                    @if (c.KaraListe) { <span class="badge danger">Kara Liste</span> }
                    @if (c.Uyari) { <span class="badge warn">Uyarı</span> }
                    @if (c.IysIzinli) { <span class="badge">İYS</span> }
                    @if (c.Pasif) { <span class="badge">Pasif</span> }
                </td>
                <td class="row-actions">
                    <a href="/cariler/@c.Id/detay" class="link">Detay</a>
                    <a href="/cariler/@c.Id/ekstre" class="link">Ekstre</a>
                    <form method="post" action="/cariler/delete" onsubmit="return confirm('Silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@c.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (_page.TotalPages > 1)
{
    <nav class="pager">
        @if (_page.HasPrev) { <a href="@PageUrl(_page.Page - 1)">← Önceki</a> }
        <span class="muted">Sayfa @_page.Page / @_page.TotalPages (@_page.Total kayıt)</span>
        @if (_page.HasNext) { <a href="@PageUrl(_page.Page + 1)">Sonraki →</a> }
    </nav>
}

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }
    [SupplyParameterFromQuery(Name = "q")] public string? Q { get; set; }
    [SupplyParameterFromQuery(Name = "tip")] public string? Tip { get; set; }
    [SupplyParameterFromQuery(Name = "iys")] public string? Iys { get; set; }
    [SupplyParameterFromQuery(Name = "uyari")] public string? UyariF { get; set; }
    [SupplyParameterFromQuery(Name = "kara")] public string? Kara { get; set; }
    [SupplyParameterFromQuery(Name = "page")] public int? Page { get; set; }

    private PagedResult<CustomerRow> _page = new([], 0, 1, 20);

    protected override async Task OnInitializedAsync()
        => _page = await Customers.SearchRowsAsync(new CustomerFilter
        {
            Query = string.IsNullOrWhiteSpace(Q) ? null : Q,
            Tip = Enum.TryParse<CariType>(Tip, out var t) ? t : null,
            IysIzinli = Iys switch { "true" => true, "false" => false, _ => null },
            Uyari = UyariF == "true" ? true : null,
            KaraListe = Kara == "true" ? true : null,
            Page = Page ?? 1
        });

    private string PageUrl(int p)
    {
        var qs = new List<string> { $"page={p}" };
        if (!string.IsNullOrEmpty(Q)) qs.Add($"q={Uri.EscapeDataString(Q)}");
        if (!string.IsNullOrEmpty(Tip)) qs.Add($"tip={Tip}");
        if (!string.IsNullOrEmpty(Iys)) qs.Add($"iys={Iys}");
        if (!string.IsNullOrEmpty(UyariF)) qs.Add($"uyari={UyariF}");
        if (!string.IsNullOrEmpty(Kara)) qs.Add($"kara={Kara}");
        return "/cariler?" + string.Join("&", qs);
    }
}
