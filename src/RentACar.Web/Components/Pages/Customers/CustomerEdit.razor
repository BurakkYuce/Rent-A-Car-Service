@page "/cariler/{Id:guid}"
@attribute [Authorize]
@inject CustomerService Customers

<PageTitle>Cari Düzenle — TürevRent</PageTitle>

<h1>Cari Düzenle</h1>

@if (_c is null)
{
    <p class="error">Cari bulunamadı.</p>
    <a href="/cariler">← Listeye dön</a>
}
else
{
    @if (!string.IsNullOrEmpty(Hata))
    {
        <p class="error">@Hata</p>
    }

    <form method="post" action="/cariler/update" class="grid-form">
        <input type="hidden" name="id" value="@_c.Id" />
        <label>Tür
            <select name="tip">
                @foreach (var t in Enum.GetValues<CariType>())
                {
                    <option value="@t" selected="@(t == _c.Tip)">@t</option>
                }
            </select>
        </label>
        <label>Ad<input name="ad" value="@_c.Ad" /></label>
        <label>Soyad<input name="soyad" value="@_c.Soyad" /></label>
        <label>TC Kimlik<input name="tcKimlik" maxlength="11" value="@_c.TcKimlik" /></label>
        <label>Ünvan<input name="unvan" value="@_c.Unvan" /></label>
        <label>Vergi Dairesi<input name="vergiDairesi" value="@_c.VergiDairesi" /></label>
        <label>Vergi No<input name="vergiNo" maxlength="10" value="@_c.VergiNo" /></label>
        <label>Cep Tel<input name="cepTel" value="@_c.CepTel" /></label>
        <label>GSM 2<input name="gsm2" value="@_c.Gsm2" /></label>
        <label>E-posta<input name="email" type="email" value="@_c.Email" /></label>
        <label>İl<input name="il" value="@_c.Il" /></label>
        <label>İlçe<input name="ilce" value="@_c.Ilce" /></label>
        <label>Kaynak<input name="kaynak" value="@_c.Kaynak" placeholder="Web/Telefon/Bayi…" /></label>
        <label>Müşteri Temsilcisi<input name="musteriTemsilcisi" value="@_c.MusteriTemsilcisi" /></label>
        <label>İYS İzinli
            <select name="iysIzinli">
                <option value="false" selected="@(!_c.IysIzinli)">Hayır</option>
                <option value="true" selected="@_c.IysIzinli">Evet</option>
            </select>
        </label>
        <label>Uyarı
            <select name="uyari">
                <option value="false" selected="@(!_c.Uyari)">Hayır</option>
                <option value="true" selected="@_c.Uyari">Evet</option>
            </select>
        </label>
        <label>Uyarı Nedeni<input name="uyariNedeni" value="@_c.UyariNedeni" /></label>
        <label>Ehliyet No<input name="ehliyetNo" value="@_c.EhliyetNo" /></label>
        <label>Ehliyet Sınıfı<input name="ehliyetSinifi" value="@_c.EhliyetSinifi" placeholder="B" /></label>
        <label>Ehliyet Tarihi<input name="ehliyetTarihi" type="date" value="@_c.EhliyetTarihi?.ToString("yyyy-MM-dd")" /></label>
        <label>Ehliyet Yeri<input name="ehliyetYeri" value="@_c.EhliyetYeri" /></label>
        <label>HGS Yansıtma Türü<input name="hgsYansitmaTuru" value="@_c.HgsYansitmaTuru" placeholder="Faturalı/Faturasız…" /></label>
        <label>Tarife<input name="tarife" value="@_c.Tarife" /></label>
        <label>Vade (gün)<input name="vadeGun" type="number" value="@_c.VadeGun" /></label>
        <label>Risk Limiti<input name="riskLimiti" type="number" step="0.01" value="@_c.RiskLimiti" /></label>
        <label>Risk Mesajı<input name="riskMesaji" value="@_c.RiskMesaji" /></label>
        <label>Risk Tarihi<input name="riskTarihi" type="date" value="@_c.RiskTarihi?.ToString("yyyy-MM-dd")" /></label>
        <label>Kara Liste
            <select name="karaListe">
                <option value="false" selected="@(!_c.KaraListe)">Hayır</option>
                <option value="true" selected="@_c.KaraListe">Evet</option>
            </select>
        </label>
        <label>Pasif
            <select name="pasif">
                <option value="false" selected="@(!_c.Pasif)">Hayır</option>
                <option value="true" selected="@_c.Pasif">Evet</option>
            </select>
        </label>
        <label>Sınıf<input name="sinif" value="@_c.Sinif" placeholder="Düşük/Orta/Yüksek/VIP…" /></label>
        <label>Mail İzin
            <select name="mailIzin">
                <option value="" selected="@(_c.MailIzin == null)">—</option>
                <option value="true" selected="@(_c.MailIzin == true)">Evet</option>
                <option value="false" selected="@(_c.MailIzin == false)">Hayır</option>
            </select>
        </label>
        <label>SMS İzin
            <select name="smsIzin">
                <option value="" selected="@(_c.SmsIzin == null)">—</option>
                <option value="true" selected="@(_c.SmsIzin == true)">Evet</option>
                <option value="false" selected="@(_c.SmsIzin == false)">Hayır</option>
            </select>
        </label>
        <label>Telefon İzin
            <select name="telefonIzin">
                <option value="" selected="@(_c.TelefonIzin == null)">—</option>
                <option value="true" selected="@(_c.TelefonIzin == true)">Evet</option>
                <option value="false" selected="@(_c.TelefonIzin == false)">Hayır</option>
            </select>
        </label>
        <label>Doğum Tarihi<input name="dogumTarihi" type="date" value="@_c.DogumTarihi?.ToString("yyyy-MM-dd")" /></label>
        <label>Baba Adı<input name="babaAdi" value="@_c.BabaAdi" /></label>
        <label>Ana Adı<input name="anaAdi" value="@_c.AnaAdi" /></label>
        <label>Pasaport No<input name="pasaportNo" value="@_c.PasaportNo" /></label>
        <label>Fatura Dönemi<input name="faturaDonemi" value="@_c.FaturaDonemi" placeholder="Aylık/15 günlük/Peşin" /></label>
        <label>Tevkifat Oranı %<input name="tevkifatOrani" type="number" step="0.01" min="0" max="100" value="@_c.TevkifatOrani" /></label>
        <label>Yetkili 1 Ad<input name="yetkili1Ad" value="@_c.Yetkili1Ad" /></label>
        <label>Yetkili 1 Tel<input name="yetkili1Tel" value="@_c.Yetkili1Tel" /></label>
        <label>Yetkili 1 Mail<input name="yetkili1Mail" type="email" value="@_c.Yetkili1Mail" /></label>
        <label>Yetkili 2 Ad<input name="yetkili2Ad" value="@_c.Yetkili2Ad" /></label>
        <label>Yetkili 2 Tel<input name="yetkili2Tel" value="@_c.Yetkili2Tel" /></label>
        <label>Yetkili 2 Mail<input name="yetkili2Mail" type="email" value="@_c.Yetkili2Mail" /></label>
        <label>Yetkili 3 Ad<input name="yetkili3Ad" value="@_c.Yetkili3Ad" /></label>
        <label>Yetkili 3 Tel<input name="yetkili3Tel" value="@_c.Yetkili3Tel" /></label>
        <label>Yetkili 3 Mail<input name="yetkili3Mail" type="email" value="@_c.Yetkili3Mail" /></label>
        <button type="submit">Güncelle</button>
        <a href="/cariler" class="link">İptal</a>
    </form>
}

@code {
    [Parameter] public Guid Id { get; set; }

    [SupplyParameterFromQuery(Name = "hata")]
    public string? Hata { get; set; }

    private Customer? _c;

    protected override async Task OnInitializedAsync()
        => _c = await Customers.GetAsync(Id);
}
