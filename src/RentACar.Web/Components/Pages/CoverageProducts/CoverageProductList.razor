@page "/sigorta-urunleri"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject CoverageProductService SigortaUrunleri

<PageTitle>Sigorta Ürünleri — TürevRent</PageTitle>

<h1>Sigorta & Ek Hizmet Ürün Kataloğu</h1>
<p class="muted small">Online/rezervasyonda satılan teminat (SCDW/CDW/IMM/LCF/PAI/Mini Hasar/Max Güvence…)
    ve paket/km hizmetlerinin fiyat & kural master'ı: günlük birim ücret + KDV + faturalama gün tavanı
    (Max Gün) + döviz + zorunluluk + TR/EN açıklama. Kira ek hizmet kalemlerinin master kaynağı; fiyat
    motorunun girdisidir. Saf fiyat-tanım — deftere kayıt postlamaz.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Ürün</summary>
    <form method="post" action="/sigorta-urunleri/create" class="grid-form"><AntiforgeryToken />
        <label>Kod<input name="kod" required placeholder="SCDW" /></label>
        <label>Ad<input name="ad" required placeholder="Süper Hasar Muafiyeti" /></label>
        <label>Ad (EN)<input name="adEn" placeholder="Super Damage Waiver" /></label>
        <label>Tür
            <select name="tur">
                @foreach (var t in Enum.GetValues<CoverageProductType>())
                {
                    <option value="@t">@t</option>
                }
            </select>
        </label>
        <label>Günlük Ücret<input name="gunlukUcret" type="number" step="0.01" min="0" /></label>
        <label>KDV %<input name="kdvOrani" type="number" step="0.01" min="0" max="100" /></label>
        <label>Max Gün<input name="maxGun" type="number" min="0" /></label>
        <label>Döviz<input name="doviz" maxlength="8" placeholder="TRY/EUR/USD" /></label>
        <label>Zorunlu
            <select name="zorunlu"><option value="false">Hayır</option><option value="true">Evet</option></select>
        </label>
        <label>Açıklama<input name="aciklama" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Tür</th><th>Günlük</th><th>Max Gün</th><th>Zorunlu</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="8" class="muted">Sigorta ürünü tanımlı değil.</td></tr>
        }
        @foreach (var r in _list)
        {
            <tr>
                <td class="mono">@r.Kod</td>
                <td>@r.Ad</td>
                <td>@r.Tur</td>
                <td class="num">@(r.GunlukUcret?.ToString("N2") ?? "—")</td>
                <td class="num">@(r.MaxGun?.ToString() ?? "—")</td>
                <td>@(r.Zorunlu ? "Evet" : "Hayır")</td>
                <td>@(r.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/sigorta-urunleri/update" class="grid-form"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@r.Id" />
                            <label>Kod<input name="kod" value="@r.Kod" required /></label>
                            <label>Ad<input name="ad" value="@r.Ad" required /></label>
                            <label>Ad (EN)<input name="adEn" value="@r.AdEn" /></label>
                            <label>Tür
                                <select name="tur">
                                    @foreach (var t in Enum.GetValues<CoverageProductType>())
                                    {
                                        <option value="@t" selected="@(r.Tur == t)">@t</option>
                                    }
                                </select>
                            </label>
                            <label>Günlük Ücret<input name="gunlukUcret" type="number" step="0.01" min="0" value="@r.GunlukUcret" /></label>
                            <label>KDV %<input name="kdvOrani" type="number" step="0.01" min="0" max="100" value="@r.KdvOrani" /></label>
                            <label>Max Gün<input name="maxGun" type="number" min="0" value="@r.MaxGun" /></label>
                            <label>Döviz<input name="doviz" maxlength="8" value="@r.Doviz" /></label>
                            <label>Zorunlu
                                <select name="zorunlu">
                                    <option value="false" selected="@(!r.Zorunlu)">Hayır</option>
                                    <option value="true" selected="@r.Zorunlu">Evet</option>
                                </select>
                            </label>
                            <label>Açıklama<input name="aciklama" value="@r.Aciklama" /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@r.Aktif">Aktif</option>
                                    <option value="false" selected="@(!r.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/sigorta-urunleri/delete" onsubmit="return confirm('Ürün silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@r.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<CoverageProduct> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await SigortaUrunleri.ListAsync();
}
