@page "/departmanlar"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject DepartmentService Departmanlar

<PageTitle>Departmanlar — TürevRent</PageTitle>

<h1>Departman Tanımları</h1>
<p class="muted small">Organizasyon birimlerinin sözlüğü (ör. "Operasyon", "Muhasebe", "Filo",
    "Satış"). Gider/personel dağıtımı ve raporlama için.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Departman</summary>
    <form method="post" action="/departmanlar/create" class="grid-form">
        <label>Kod<input name="kod" required placeholder="OPERASYON" /></label>
        <label>Ad<input name="ad" required placeholder="Operasyon" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="4" class="muted">Departman tanımlı değil.</td></tr>
        }
        @foreach (var d in _list)
        {
            <tr>
                <td class="mono">@d.Kod</td>
                <td>@d.Ad</td>
                <td>@(d.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/departmanlar/update" class="grid-form">
                            <input type="hidden" name="id" value="@d.Id" />
                            <label>Kod<input name="kod" value="@d.Kod" required /></label>
                            <label>Ad<input name="ad" value="@d.Ad" required /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@d.Aktif">Aktif</option>
                                    <option value="false" selected="@(!d.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/departmanlar/delete" onsubmit="return confirm('Departman silinsin mi?')">
                        <input type="hidden" name="id" value="@d.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<Department> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await Departmanlar.ListAsync();
}
