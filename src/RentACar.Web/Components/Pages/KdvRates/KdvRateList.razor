@page "/kdv-oranlari"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject KdvRateService KdvOranlari

<PageTitle>KDV Oranları — TürevRent</PageTitle>

<h1>KDV Oranı Tanımları</h1>
<p class="muted small">Adlandırılmış KDV oranları sözlüğü (ör. "Genel %20" = 0.20, "İndirimli %10" = 0.10).
    Oran 0..1 olarak girilir (0.20 = %20). Saf tanım tablosudur; mevcut fatura/gider KDV alanlarını
    şimdilik değiştirmez.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni KDV Oranı</summary>
    <form method="post" action="/kdv-oranlari/create" class="grid-form"><AntiforgeryToken />
        <label>Kod<input name="kod" required placeholder="KDV20" /></label>
        <label>Ad<input name="ad" required placeholder="Genel %20" /></label>
        <label>Oran<input name="oran" type="number" step="0.01" min="0" max="1" value="0.20" placeholder="0.20 = %20" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Oran</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="5" class="muted">KDV oranı tanımlı değil.</td></tr>
        }
        @foreach (var r in _list)
        {
            <tr>
                <td class="mono">@r.Kod</td>
                <td>@r.Ad</td>
                <td class="num">@($"%{r.Oran * 100:0.##}")</td>
                <td>@(r.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/kdv-oranlari/update" class="grid-form"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@r.Id" />
                            <label>Kod<input name="kod" value="@r.Kod" required /></label>
                            <label>Ad<input name="ad" value="@r.Ad" required /></label>
                            <label>Oran<input name="oran" type="number" step="0.01" min="0" max="1" value="@r.Oran" /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@r.Aktif">Aktif</option>
                                    <option value="false" selected="@(!r.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/kdv-oranlari/delete" onsubmit="return confirm('KDV oranı silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@r.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<KdvRate> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await KdvOranlari.ListAsync();
}
