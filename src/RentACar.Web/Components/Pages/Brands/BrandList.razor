@page "/markalar"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject BrandService Markalar

<PageTitle>Markalar — TürevRent</PageTitle>

<h1>Marka Tanımları</h1>
<p class="muted small">Araç markalarının sözlüğü (Fiat, Renault…). Araç kayıt/düzenleme formundaki
    Marka açılır listesi buradan beslenir.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Marka</summary>
    <form method="post" action="/markalar/create" class="grid-form">
        <label>Kod<input name="kod" required placeholder="FIAT" /></label>
        <label>Ad<input name="ad" required placeholder="Fiat" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="4" class="muted">Marka tanımlı değil.</td></tr>
        }
        @foreach (var m in _list)
        {
            <tr>
                <td class="mono">@m.Kod</td>
                <td>@m.Ad</td>
                <td>@(m.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/markalar/update" class="grid-form">
                            <input type="hidden" name="id" value="@m.Id" />
                            <label>Kod<input name="kod" value="@m.Kod" required /></label>
                            <label>Ad<input name="ad" value="@m.Ad" required /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@m.Aktif">Aktif</option>
                                    <option value="false" selected="@(!m.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/markalar/delete" onsubmit="return confirm('Marka silinsin mi?')">
                        <input type="hidden" name="id" value="@m.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<Brand> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await Markalar.ListAsync();
}
