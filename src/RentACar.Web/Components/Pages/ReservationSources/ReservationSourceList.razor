@page "/rezervasyon-kaynaklari"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject ReservationSourceService RezKaynaklari

<PageTitle>Rezervasyon Kaynakları — TürevRent</PageTitle>

<h1>Rezervasyon Kaynağı Tanımları</h1>
<p class="muted small">Rezervasyon/müşteri kaynaklarının sözlüğü (ör. "Web", "Telefon", "Bayi",
    "Tavsiye"). Rezervasyon ve cari formlarındaki Kaynak açılır listesini besler.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Kaynak</summary>
    <form method="post" action="/rezervasyon-kaynaklari/create" class="grid-form"><AntiforgeryToken />
        <label>Kod<input name="kod" required placeholder="WEB" /></label>
        <label>Ad<input name="ad" required placeholder="Web Sitesi" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="4" class="muted">Rezervasyon kaynağı tanımlı değil.</td></tr>
        }
        @foreach (var s in _list)
        {
            <tr>
                <td class="mono">@s.Kod</td>
                <td>@s.Ad</td>
                <td>@(s.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/rezervasyon-kaynaklari/update" class="grid-form"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@s.Id" />
                            <label>Kod<input name="kod" value="@s.Kod" required /></label>
                            <label>Ad<input name="ad" value="@s.Ad" required /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@s.Aktif">Aktif</option>
                                    <option value="false" selected="@(!s.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/rezervasyon-kaynaklari/delete" onsubmit="return confirm('Kaynak silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@s.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<ReservationSource> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await RezKaynaklari.ListAsync();
}
