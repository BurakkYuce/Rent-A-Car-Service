@page "/kira-kurallari"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject RentalRuleService KiralamaKurallari

<PageTitle>Kiralama Kuralları — TürevRent</PageTitle>

<h1>Kiralama Kuralları (Promosyon / Şart)</h1>
<p class="muted small">Tarih/gün/min-max gün bazlı promosyon-kampanya-indirim kuralı + kira/rezervasyon
    şart metni. Şube + kanal (rez kaynağı) + araç grubu kapsamına uygulanır. Saf kural-tanım — deftere
    kayıt postlamaz; fiyat motorunda indirim/min-gün girdisidir.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Kural</summary>
    <form method="post" action="/kira-kurallari/create" class="grid-form"><AntiforgeryToken />
        <label>Kod<input name="kod" required placeholder="YAZ-KAMP" /></label>
        <label>Ad<input name="ad" required placeholder="Yaz Kampanyası" /></label>
        <label>Açıklama<input name="aciklama" /></label>
        <label>Kanal<input name="kanal" placeholder="WEB/ACENTA" /></label>
        <label>Şube<input name="sube" /></label>
        <label>Araç Grubu Kodu<input name="aracGrupKod" placeholder="EKO" /></label>
        <label>Min Gün<input name="minGun" type="number" min="0" /></label>
        <label>Max Gün<input name="maxGun" type="number" min="0" /></label>
        <label>İskonto %<input name="iskonto" type="number" step="0.01" min="0" max="100" /></label>
        <label>Hafta Sonu Fark %<input name="haftaSonuFarkOran" type="number" step="0.01" min="0" max="200" /></label>
        <label>Sonra Öde %<input name="sonraOdeOran" type="number" step="0.01" min="0" max="100" /></label>
        <label>Hediye Gün<input name="hediyeGun" type="number" min="0" /></label>
        <label>Kampanya mı
            <select name="kampanyaMi"><option value="false">Hayır</option><option value="true">Evet</option></select>
        </label>
        <label>Kampanya Kodu<input name="kampanyaKodu" /></label>
        <label>Geçerlilik Baş<input name="gecerlilikBas" type="date" /></label>
        <label>Geçerlilik Bit<input name="gecerlilikBit" type="date" /></label>
        <label>Şart Metni<input name="sartMetni" placeholder="Rez/sözleşme şartları" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Kanal</th><th>Min/Max</th><th>İskonto</th><th>Kampanya</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="8" class="muted">Kiralama kuralı tanımlı değil.</td></tr>
        }
        @foreach (var r in _list)
        {
            <tr>
                <td class="mono">@r.Kod</td>
                <td>@r.Ad</td>
                <td>@r.Kanal</td>
                <td class="num">@(r.MinGun?.ToString() ?? "—") / @(r.MaxGun?.ToString() ?? "—")</td>
                <td class="num">@(r.Iskonto?.ToString("N2") ?? "—")</td>
                <td>@(r.KampanyaMi ? "Evet" : "Hayır")</td>
                <td>@(r.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/kira-kurallari/update" class="grid-form"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@r.Id" />
                            <label>Kod<input name="kod" value="@r.Kod" required /></label>
                            <label>Ad<input name="ad" value="@r.Ad" required /></label>
                            <label>Açıklama<input name="aciklama" value="@r.Aciklama" /></label>
                            <label>Kanal<input name="kanal" value="@r.Kanal" /></label>
                            <label>Şube<input name="sube" value="@r.Sube" /></label>
                            <label>Araç Grubu Kodu<input name="aracGrupKod" value="@r.AracGrupKod" /></label>
                            <label>Min Gün<input name="minGun" type="number" min="0" value="@r.MinGun" /></label>
                            <label>Max Gün<input name="maxGun" type="number" min="0" value="@r.MaxGun" /></label>
                            <label>İskonto %<input name="iskonto" type="number" step="0.01" min="0" max="100" value="@r.Iskonto" /></label>
                            <label>Hafta Sonu Fark %<input name="haftaSonuFarkOran" type="number" step="0.01" min="0" max="200" value="@r.HaftaSonuFarkOran" /></label>
                            <label>Sonra Öde %<input name="sonraOdeOran" type="number" step="0.01" min="0" max="100" value="@r.SonraOdeOran" /></label>
                            <label>Hediye Gün<input name="hediyeGun" type="number" min="0" value="@r.HediyeGun" /></label>
                            <label>Kampanya mı
                                <select name="kampanyaMi">
                                    <option value="false" selected="@(!r.KampanyaMi)">Hayır</option>
                                    <option value="true" selected="@r.KampanyaMi">Evet</option>
                                </select>
                            </label>
                            <label>Kampanya Kodu<input name="kampanyaKodu" value="@r.KampanyaKodu" /></label>
                            <label>Geçerlilik Baş<input name="gecerlilikBas" type="date" value="@r.GecerlilikBas?.ToString("yyyy-MM-dd")" /></label>
                            <label>Geçerlilik Bit<input name="gecerlilikBit" type="date" value="@r.GecerlilikBit?.ToString("yyyy-MM-dd")" /></label>
                            <label>Şart Metni<input name="sartMetni" value="@r.SartMetni" /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@r.Aktif">Aktif</option>
                                    <option value="false" selected="@(!r.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/kira-kurallari/delete" onsubmit="return confirm('Kural silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@r.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<RentalRule> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await KiralamaKurallari.ListAsync();
}
