@page "/ozel-kodlar"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject CustomCodeService OzelKodlar

<PageTitle>Özel Kodlar — TürevRent</PageTitle>

<h1>Özel Kod Tanımları</h1>
<p class="muted small">Kullanıcı tanımlı serbest sınıflandırma kodları (ör. "VIP", "Filo-A",
    "Kampanya-X"). Araç/cari/rezervasyon formlarındaki Özel Kod açılır listesini besler.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Özel Kod</summary>
    <form method="post" action="/ozel-kodlar/create" class="grid-form"><AntiforgeryToken />
        <label>Kod<input name="kod" required placeholder="VIP" /></label>
        <label>Ad<input name="ad" required placeholder="VIP Müşteri" /></label>
        <label>Açıklama<input name="aciklama" placeholder="(opsiyonel)" /></label>
        <label>Tür<input name="turu" placeholder="(opsiyonel sınıflandırma)" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Açıklama</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="5" class="muted">Özel kod tanımlı değil.</td></tr>
        }
        @foreach (var c in _list)
        {
            <tr>
                <td class="mono">@c.Kod</td>
                <td>@c.Ad</td>
                <td>@c.Aciklama</td>
                <td>@(c.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/ozel-kodlar/update" class="grid-form"><AntiforgeryToken />
                            <input type="hidden" name="id" value="@c.Id" />
                            <label>Kod<input name="kod" value="@c.Kod" required /></label>
                            <label>Ad<input name="ad" value="@c.Ad" required /></label>
                            <label>Açıklama<input name="aciklama" value="@c.Aciklama" /></label>
                            <label>Tür<input name="turu" value="@c.Turu" /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@c.Aktif">Aktif</option>
                                    <option value="false" selected="@(!c.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/ozel-kodlar/delete" onsubmit="return confirm('Özel kod silinsin mi?')"><AntiforgeryToken />
                        <input type="hidden" name="id" value="@c.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<CustomCode> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await OzelKodlar.ListAsync();
}
