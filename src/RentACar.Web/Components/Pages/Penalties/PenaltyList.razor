@page "/cezalar"
@attribute [Authorize]
@using RentACar.Domain.Enums
@inject PenaltyService Penalties
@inject VehicleService Vehicles
@inject CustomerService Customers

<PageTitle>Cezalar — TürevRent</PageTitle>

<h1>Trafik Cezaları</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Ceza</summary>
    <form method="post" action="/cezalar/create" class="grid-form">
        <label>Ceza Türü<input name="cezaTuru" required /></label>
        <label>Tebliğ Tarihi<input name="tebligTarihi" type="date" /></label>
        <label>Vade (gün)<input name="vadeGun" type="number" value="15" /></label>
        <label>Araç
            <select name="vehicleId">
                <option value="">—</option>
                @foreach (var v in _vehicles)
                {
                    <option value="@v.Id">@v.Plaka</option>
                }
            </select>
        </label>
        <label>Müşteri (Cari)
            <select name="cariId">
                <option value="">—</option>
                @foreach (var c in _customers)
                {
                    <option value="@c.Id">@c.DisplayName</option>
                }
            </select>
        </label>
        <label>Tutar<input name="tutar" type="number" step="0.01" required /></label>
        <label>Sebep<input name="sebep" /></label>
        <button type="submit">Kaydet</button>
    </form>
</details>

<table class="grid">
    <thead>
        <tr><th>No</th><th>Tür</th><th>Tebliğ</th><th>Vade</th><th>Araç</th><th>Müşteri</th><th>Tutar</th><th>Durum</th><th></th></tr>
    </thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="9" class="muted">Ceza yok.</td></tr>
        }
        @foreach (var p in _list)
        {
            <tr>
                <td>@p.No</td>
                <td>@p.CezaTuru</td>
                <td>@p.TebligTarihi.LocalDateTime.ToString("dd.MM.yyyy")</td>
                <td>@p.VadeTarihi.LocalDateTime.ToString("dd.MM.yyyy")</td>
                <td>@VehLabel(p.VehicleId)</td>
                <td>@CustLabel(p.CariId)</td>
                <td>@p.Tutar.ToString("N2")</td>
                <td>@p.Durum</td>
                <td>
                    @if (p.Durum == CezaDurum.Yeni && p.CariId is not null)
                    {
                        <form method="post" action="/cezalar/yansit" class="inline">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit">Yansıt</button>
                        </form>
                    }
                    @if (p.Durum is CezaDurum.Yeni or CezaDurum.Yansitildi)
                    {
                        <form method="post" action="/cezalar/ode" class="inline">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit">Öde</button>
                        </form>
                    }
                    @if (p.Durum == CezaDurum.Yeni)
                    {
                        <form method="post" action="/cezalar/iptal" class="inline">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit">İptal</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<Penalty> _list = [];
    private IReadOnlyList<Vehicle> _vehicles = [];
    private IReadOnlyList<Customer> _customers = [];
    private Dictionary<Guid, string> _vehMap = new();
    private Dictionary<Guid, string> _custMap = new();

    protected override async Task OnInitializedAsync()
    {
        _list = await Penalties.ListAsync();
        _vehicles = await Vehicles.ListAsync();
        _customers = await Customers.ListAsync();
        _vehMap = _vehicles.ToDictionary(v => v.Id, v => v.Plaka);
        _custMap = _customers.ToDictionary(c => c.Id, c => c.DisplayName);
    }

    private string VehLabel(Guid? id)
        => id is Guid v && _vehMap.TryGetValue(v, out var p) ? p : "—";
    private string CustLabel(Guid? id)
        => id is Guid c && _custMap.TryGetValue(c, out var n) ? n : "—";
}
