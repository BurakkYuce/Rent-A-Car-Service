@page "/odeme-tipleri"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject PaymentTypeService OdemeTipleri

<PageTitle>Ödeme Tipleri — TürevRent</PageTitle>

<h1>Ödeme Tipi Tanımları</h1>
<p class="muted small">Tahsilat/ödeme yöntemlerinin sözlüğü (ör. "Nakit", "Kredi Kartı", "Havale/EFT",
    "Çek"). Kasa/banka formlarındaki Ödeme Tipi açılır listesini besler.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Ödeme Tipi</summary>
    <form method="post" action="/odeme-tipleri/create" class="grid-form">
        <label>Kod<input name="kod" required placeholder="NAKIT" /></label>
        <label>Ad<input name="ad" required placeholder="Nakit" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="4" class="muted">Ödeme tipi tanımlı değil.</td></tr>
        }
        @foreach (var t in _list)
        {
            <tr>
                <td class="mono">@t.Kod</td>
                <td>@t.Ad</td>
                <td>@(t.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/odeme-tipleri/update" class="grid-form">
                            <input type="hidden" name="id" value="@t.Id" />
                            <label>Kod<input name="kod" value="@t.Kod" required /></label>
                            <label>Ad<input name="ad" value="@t.Ad" required /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@t.Aktif">Aktif</option>
                                    <option value="false" selected="@(!t.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/odeme-tipleri/delete" onsubmit="return confirm('Ödeme tipi silinsin mi?')">
                        <input type="hidden" name="id" value="@t.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<PaymentType> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await OdemeTipleri.ListAsync();
}
