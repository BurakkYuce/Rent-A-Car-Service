@page "/kiralar"
@attribute [Authorize]
@inject RentalService Rentals
@inject CustomerService Customers
@inject VehicleService Vehicles
@inject LocationService Locations

<PageTitle>Kira Sözleşmeleri — TürevRent</PageTitle>

<h1>Kira Sözleşmeleri</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Kira (doğrudan — rezervasyonsuz)</summary>
    <form method="post" action="/kiralar/create" class="grid-form">
        <label>Müşteri
            <select name="musteriId" required>
                <option value="">—</option>
                @foreach (var c in _customers) { <option value="@c.Id">@c.DisplayName</option> }
            </select>
        </label>
        <label>Araç
            <select name="vehicleId" required>
                <option value="">—</option>
                @foreach (var v in _vehicles) { <option value="@v.Id">@v.Plaka</option> }
            </select>
        </label>
        <label>Başlangıç<input name="basTar" type="datetime-local" required /></label>
        <label>Bitiş<input name="bitTar" type="datetime-local" required /></label>
        <label>Günlük Ücret<input name="gunlukUcret" type="number" step="0.01" required /></label>
        <label>Çıkış Ofisi
            <select name="cikisOfisi">
                <option value="">—</option>
                @foreach (var o in _locations) { <option>@o.Ad</option> }
            </select>
        </label>
        <label>Dönüş Ofisi
            <select name="donusOfisi">
                <option value="">—</option>
                @foreach (var o in _locations) { <option>@o.Ad</option> }
            </select>
        </label>
        <button type="submit">Kira Aç</button>
    </form>
</details>

<table class="grid">
    <thead>
        <tr><th>Sözleşme No</th><th>Müşteri</th><th>Araç</th><th>Tarih</th><th>Gün</th><th>Tutar</th><th>Bakiye</th><th>Durum</th><th></th></tr>
    </thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="9" class="muted">Kira sözleşmesi yok. Rezervasyonlardan "Kiraya Çevir" ile oluşturabilirsiniz.</td></tr>
        }
        @foreach (var r in _list)
        {
            <tr>
                <td><a href="/kiralar/@r.Id">@r.SozlesmeNo</a></td>
                <td>@Cust(r.MusteriId)</td>
                <td>@Veh(r.VehicleId)</td>
                <td>@r.BasTar.LocalDateTime.ToString("dd.MM.yyyy HH:mm") – @r.BitTar.LocalDateTime.ToString("dd.MM HH:mm")</td>
                <td>@r.Gun</td>
                <td>@r.Tutar.ToString("N2")</td>
                <td>@r.Bakiye.ToString("N2")</td>
                <td>@r.Durum</td>
                <td class="row-actions">
                    <a href="/kiralar/@r.Id/yazdir" class="link">Sözleşme</a>
                    @if (r.Durum == RentalStatus.Kirada)
                    {
                        <form method="post" action="/kiralar/cancel" onsubmit="return confirm('İptal edilsin mi?')"><input type="hidden" name="id" value="@r.Id" /><button class="link danger">İptal</button></form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<RentalContract> _list = [];
    private IReadOnlyList<Customer> _customers = [];
    private IReadOnlyList<Vehicle> _vehicles = [];
    private IReadOnlyList<Location> _locations = [];
    private Dictionary<Guid, string> _custMap = new();
    private Dictionary<Guid, string> _vehMap = new();

    protected override async Task OnInitializedAsync()
    {
        _list = await Rentals.ListAsync();
        _customers = await Customers.ListAsync();
        _vehicles = await Vehicles.ListAsync();
        _locations = await Locations.ListActiveAsync();
        _custMap = _customers.ToDictionary(c => c.Id, c => c.DisplayName);
        _vehMap = _vehicles.ToDictionary(v => v.Id, v => v.Plaka);
    }

    private string Cust(Guid id) => _custMap.GetValueOrDefault(id, "—");
    private string Veh(Guid id) => _vehMap.GetValueOrDefault(id, "—");
}
