@page "/teklifler"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject QuotationService Quotations
@inject CustomerService Customers
@inject VehicleService Vehicles

<PageTitle>Teklifler — TürevRent</PageTitle>

<h1>Teklifler</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Teklif</summary>
    <form method="post" action="/teklifler/create" class="grid-form">
        <label>Müşteri
            <select name="musteriId" required>
                <option value="">— seç —</option>
                @foreach (var c in _customers)
                {
                    <option value="@c.Id">@c.DisplayName</option>
                }
            </select>
        </label>
        <label>Araç
            <select name="vehicleId" required>
                <option value="">— seç —</option>
                @foreach (var v in _vehicles)
                {
                    <option value="@v.Id">@v.Plaka</option>
                }
            </select>
        </label>
        <label>Başlangıç<input name="basTar" type="datetime-local" value="@_defBas" required /></label>
        <label>Bitiş<input name="bitTar" type="datetime-local" value="@_defBit" required /></label>
        <label>Günlük Ücret<input name="gunlukUcret" type="number" step="0.01" value="0" /></label>
        <label>Geçerlilik<input name="gecerlilik" type="date" /></label>
        <label>Çıkış Ofisi<input name="cikisOfisi" /></label>
        <label>Dönüş Ofisi<input name="donusOfisi" /></label>
        <button type="submit">Teklif Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead>
        <tr><th>No</th><th>Müşteri</th><th>Araç</th><th>Tarih</th><th>Gün</th><th>Tutar</th><th>Geçerlilik</th><th>Durum</th><th></th></tr>
    </thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="9" class="muted">Teklif yok.</td></tr>
        }
        @foreach (var t in _list)
        {
            <tr>
                <td class="mono">@t.No</td>
                <td>@Cust(t.MusteriId)</td>
                <td>@Veh(t.VehicleId)</td>
                <td>@t.BasTar.LocalDateTime.ToString("dd.MM.yyyy") – @t.BitTar.LocalDateTime.ToString("dd.MM.yyyy")</td>
                <td>@t.Gun</td>
                <td>@t.Tutar.ToString("N2")</td>
                <td>@(t.GecerlilikTarihi?.LocalDateTime.ToString("dd.MM.yyyy") ?? "—")</td>
                <td>
                    @if (t.Durum == QuotationStatus.Kabul && t.ReservationId is { } rid)
                    {
                        <a href="/rezervasyonlar">@t.Durum</a>
                    }
                    else { @t.Durum }
                </td>
                <td class="row-actions">
                    @if (t.Durum == QuotationStatus.Taslak)
                    {
                        <form method="post" action="/teklifler/gonder"><input type="hidden" name="id" value="@t.Id" /><button class="link">Gönder</button></form>
                    }
                    @if (t.Durum is QuotationStatus.Taslak or QuotationStatus.Gonderildi)
                    {
                        <form method="post" action="/teklifler/kabul" onsubmit="return confirm('Teklif kabul edilip rezervasyona çevrilsin mi?')"><input type="hidden" name="id" value="@t.Id" /><button class="link">Kabul → Rezervasyon</button></form>
                        <form method="post" action="/teklifler/reddet" onsubmit="return confirm('Reddedilsin mi?')"><input type="hidden" name="id" value="@t.Id" /><button class="link danger">Reddet</button></form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<Quotation> _list = [];
    private IReadOnlyList<Customer> _customers = [];
    private IReadOnlyList<Vehicle> _vehicles = [];
    private Dictionary<Guid, string> _custMap = new();
    private Dictionary<Guid, string> _vehMap = new();
    private readonly string _defBas = DateTime.Now.ToString("yyyy-MM-ddT09:00");
    private readonly string _defBit = DateTime.Now.AddDays(3).ToString("yyyy-MM-ddT09:00");

    protected override async Task OnInitializedAsync()
    {
        _list = await Quotations.ListAsync();
        _customers = await Customers.ListAsync();
        _vehicles = await Vehicles.ListAsync();
        _custMap = _customers.ToDictionary(c => c.Id, c => c.DisplayName);
        _vehMap = _vehicles.ToDictionary(v => v.Id, v => v.Plaka);
    }

    private string Cust(Guid id) => _custMap.GetValueOrDefault(id, "—");
    private string Veh(Guid id) => _vehMap.GetValueOrDefault(id, "—");
}
