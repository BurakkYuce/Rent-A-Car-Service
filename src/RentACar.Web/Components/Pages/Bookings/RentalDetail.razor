@page "/kiralar/{Id:guid}"
@attribute [Authorize]
@inject RentalService Rentals
@inject RentACar.Application.RentalAddOns.RentalAddOnService EkHizmetler
@inject EkHizmetTanimService EkHizmetTanimlari

<PageTitle>Kira Detayı — TürevRent</PageTitle>

@if (_c is null)
{
    <p class="error">Kira sözleşmesi bulunamadı.</p>
    <a href="/kiralar">← Listeye dön</a>
}
else
{
    <h1>Kira @_c.SozlesmeNo <span class="badge">@_c.Durum</span></h1>

    @if (!string.IsNullOrEmpty(Hata))
    {
        <p class="error">@Hata</p>
    }

    <table class="kv">
        <tr><th>Tarih</th><td>@_c.BasTar.LocalDateTime.ToString("dd.MM.yyyy HH:mm") – @_c.BitTar.LocalDateTime.ToString("dd.MM.yyyy HH:mm") (@_c.Gun gün)</td></tr>
        <tr><th>Günlük / KM Limit / Fazla KM Ücret / Yakıt Birim</th><td>@_c.GunlukUcret.ToString("N2") / @_c.KmLimit / @_c.FazlaKmUcret.ToString("N2") / @_c.YakitBirimUcret.ToString("N2")</td></tr>
        <tr><th>Çıkış (KM / Yakıt)</th><td>@(_c.CikisKm?.ToString() ?? "—") / @(_c.CikisYakit?.ToString() ?? "—")</td></tr>
        <tr><th>Dönüş (KM / Yakıt / Tarih)</th><td>@(_c.DonusKm?.ToString() ?? "—") / @(_c.DonusYakit?.ToString() ?? "—") / @(_c.GercekDonusTar?.LocalDateTime.ToString("dd.MM.yyyy HH:mm") ?? "—")</td></tr>
        <tr><th>Fazla KM / Bedel</th><td>@_c.FazlaKm / @_c.FazlaKmBedeli.ToString("N2")</td></tr>
        <tr><th>Eksik Yakıt / Bedel</th><td>@_c.EksikYakit / @_c.YakitBedeli.ToString("N2")</td></tr>
        <tr><th>Uzatma Gün / Bedel</th><td>@_c.UzatmaGun / @_c.UzatmaBedeli.ToString("N2")</td></tr>
        <tr><th>Baz Tutar / Genel Toplam / Bakiye</th><td>@_c.Tutar.ToString("N2") / <strong>@_c.GenelToplam.ToString("N2")</strong> / @_c.Bakiye.ToString("N2")</td></tr>
    </table>

    @if (_c.Durum == RentalStatus.Kirada && _c.CikisKm is null)
    {
        <h2>Teslim (Çıkış)</h2>
        <form method="post" action="/kiralar/teslim" class="grid-form">
            <input type="hidden" name="id" value="@_c.Id" />
            <label>Çıkış KM<input name="cikisKm" type="number" value="0" required /></label>
            <label>Çıkış Yakıt (0–12)<input name="cikisYakit" type="number" value="8" required /></label>
            <button type="submit">Teslim Et</button>
        </form>
    }

    @if (_c.Durum == RentalStatus.Kirada && _c.CikisKm is not null)
    {
        <h2>Dönüş</h2>
        <form method="post" action="/kiralar/donus" class="grid-form">
            <input type="hidden" name="id" value="@_c.Id" />
            <label>Dönüş KM<input name="donusKm" type="number" value="@_c.CikisKm" required /></label>
            <label>Dönüş Yakıt (0–12)<input name="donusYakit" type="number" value="@_c.CikisYakit" required /></label>
            <label>Gerçek Dönüş<input name="gercekDonus" type="datetime-local" value="@_c.BitTar.LocalDateTime.ToString("yyyy-MM-ddTHH:mm")" required /></label>
            <button type="submit">Dönüşü Tamamla</button>
        </form>
    }

    <h2>Ek Hizmetler</h2>
    <table class="grid">
        <thead><tr><th>Hizmet</th><th>Miktar</th><th>Birim NET</th><th>KDV</th><th>Net</th><th>KDV Tutar</th><th>Toplam</th><th></th></tr></thead>
        <tbody>
            @if (_addons.Count == 0)
            {
                <tr><td colspan="8" class="muted">Ek hizmet eklenmemiş.</td></tr>
            }
            @foreach (var a in _addons)
            {
                <tr>
                    <td>@a.Ad</td>
                    <td class="num">@a.Miktar</td>
                    <td class="num">@a.BirimNetFiyat.ToString("N2")</td>
                    <td class="num">@($"%{a.KdvOrani * 100:0.##}")</td>
                    <td class="num">@a.NetTutar.ToString("N2")</td>
                    <td class="num">@a.KdvTutar.ToString("N2")</td>
                    <td class="num">@a.Toplam.ToString("N2")</td>
                    <td>
                        <form method="post" action="/kiralar/ekhizmet-sil" onsubmit="return confirm('Ek hizmet silinsin mi?')">
                            <input type="hidden" name="addOnId" value="@a.Id" />
                            <input type="hidden" name="rentalId" value="@_c.Id" />
                            <button type="submit" class="link danger">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (_c.Durum != RentalStatus.Iptal)
    {
        <form method="post" action="/kiralar/ekhizmet-ekle" class="grid-form">
            <input type="hidden" name="rentalId" value="@_c.Id" />
            <label>Hizmet
                <select name="ekHizmetTanimId" required>
                    <option value="">— seç —</option>
                    @foreach (var t in _tanimlar)
                    {
                        <option value="@t.Id">@t.Ad (@t.BirimUcret.ToString("N2") net)</option>
                    }
                </select>
            </label>
            <label>Miktar<input name="miktar" type="number" step="0.01" min="0.01" value="1" required /></label>
            <button type="submit">Ekle</button>
        </form>
    }

    @if (_c.Bakiye > 0 && _c.Durum != RentalStatus.Iptal)
    {
        <h2>Tahsilat</h2>
        <form method="post" action="/finans/tahsilat" class="grid-form">
            <input type="hidden" name="cariId" value="@_c.MusteriId" />
            <input type="hidden" name="rentalId" value="@_c.Id" />
            <input type="hidden" name="donus" value="/kiralar/@_c.Id" />
            <label>Tutar<input name="tutar" type="number" step="0.01" value="@_c.Bakiye" required /></label>
            <label>Döviz<select name="doviz"><option>TRY</option><option>USD</option><option>EUR</option></select></label>
            <label>Kur<input name="kur" type="number" step="0.0001" value="1" /></label>
            <button type="submit">Tahsil Et</button>
        </form>
    }

    @if (_c.GenelToplam > 0 && _c.Durum != RentalStatus.Iptal)
    {
        <form method="post" action="/finans/fatura" style="margin-top:1rem">
            <input type="hidden" name="rentalId" value="@_c.Id" />
            <details>
                <summary class="link">Vergi/belge alanları (opsiyonel)</summary>
                <div class="grid-form">
                    <label>ÖTV<input name="otv" type="number" step="0.01" min="0" /></label>
                    <label>Tevkifat Oran %<input name="tevkifatOran" type="number" step="0.01" min="0" max="100" /></label>
                    <label>Tevkifat Tutar<input name="tevkifatTutar" type="number" step="0.01" min="0" /></label>
                    <label>Damga Vergisi<input name="damgaVergisi" type="number" step="0.01" min="0" /></label>
                    <label>İade Faturası
                        <select name="iadeMi"><option value="false">Hayır</option><option value="true">Evet</option></select>
                    </label>
                    <label>Manuel Fatura
                        <select name="manuelMi"><option value="false">Hayır</option><option value="true">Evet</option></select>
                    </label>
                </div>
            </details>
            <button type="submit">Fatura Kes (KDV %20)</button>
        </form>
    }

    <p><a href="/kiralar">← Kiralar</a> &nbsp; <a href="/cariler/@_c.MusteriId/ekstre">Cari Ekstre →</a></p>
}

@code {
    [Parameter] public Guid Id { get; set; }
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private RentalContract? _c;
    private IReadOnlyList<RentACar.Domain.Entities.RentalAddOn> _addons = [];
    private IReadOnlyList<RentACar.Domain.Entities.EkHizmetTanim> _tanimlar = [];

    protected override async Task OnInitializedAsync()
    {
        _c = await Rentals.GetAsync(Id);
        if (_c is not null)
        {
            _addons = await EkHizmetler.ListAsync(Id);
            _tanimlar = await EkHizmetTanimlari.ListActiveAsync();
        }
    }
}
