@page "/rezervasyonlar"
@attribute [Authorize]
@inject ReservationService Reservations
@inject CustomerService Customers
@inject VehicleService Vehicles
@inject LocationService Locations
@inject ReservationSourceService Kaynaklar

<PageTitle>Rezervasyonlar — TürevRent</PageTitle>

<h1>Rezervasyonlar</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Rezervasyon</summary>
    <form method="post" action="/rezervasyonlar/create" class="grid-form"><AntiforgeryToken />
        <label>Müşteri
            <select name="musteriId" required>
                <option value="">— seç —</option>
                @foreach (var c in _customers)
                {
                    <option value="@c.Id">@c.DisplayName</option>
                }
            </select>
        </label>
        <label>Araç
            <select name="vehicleId" required>
                <option value="">— seç —</option>
                @foreach (var v in _vehicles)
                {
                    <option value="@v.Id">@v.Plaka</option>
                }
            </select>
        </label>
        <label>Başlangıç<input name="basTar" type="datetime-local" value="@_defBas" required /></label>
        <label>Bitiş<input name="bitTar" type="datetime-local" value="@_defBit" required /></label>
        <label>Günlük Ücret<input name="gunlukUcret" type="number" step="0.01" value="0" /></label>
        <details>
            <summary class="link">Ödeme/komisyon (bilgi amaçlı — deftere/bakiyeye yansımaz)</summary>
            <div class="grid-form">
                <label>Provizyon<input name="provizyon" type="number" step="0.01" min="0" /></label>
                <label>Depozito<input name="depozito" type="number" step="0.01" min="0" /></label>
                <label>Komisyon %<input name="komisyonOran" type="number" step="0.01" min="0" /></label>
                <label>Komisyon Tutar<input name="komisyonTutar" type="number" step="0.01" min="0" /></label>
                <label>Drop Ücreti<input name="dropUcreti" type="number" step="0.01" min="0" /></label>
                <label>Sonra Öde %<input name="sonraOdeOran" type="number" step="0.01" min="0" /></label>
            </div>
        </details>
        <label>Çıkış Ofisi
            <select name="cikisOfisi">
                <option value="">—</option>
                @foreach (var o in _locations) { <option>@o.Ad</option> }
            </select>
        </label>
        <label>Dönüş Ofisi
            <select name="donusOfisi">
                <option value="">—</option>
                @foreach (var o in _locations) { <option>@o.Ad</option> }
            </select>
        </label>
        <label>Kaynak
            <select name="kaynak">
                <option value="">—</option>
                @foreach (var k in _kaynaklar) { <option>@k.Ad</option> }
            </select>
        </label>
        <button type="submit">Kaydet</button>
    </form>
</details>

<table class="grid">
    <thead>
        <tr><th>No</th><th>Müşteri</th><th>Araç</th><th>Tarih</th><th>Gün</th><th>Tutar</th><th>Durum</th><th></th></tr>
    </thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="8" class="muted">Rezervasyon yok.</td></tr>
        }
        @foreach (var r in _list)
        {
            <tr>
                <td>@r.ReservationNo</td>
                <td>@Cust(r.MusteriId)</td>
                <td>@Veh(r.VehicleId)</td>
                <td>@r.BasTar.LocalDateTime.ToString("dd.MM.yyyy HH:mm") – @r.BitTar.LocalDateTime.ToString("dd.MM HH:mm")</td>
                <td>@r.Gun</td>
                <td>@r.Tutar.ToString("N2")</td>
                <td>@r.Durum</td>
                <td class="row-actions">
                    @if (r.Durum == ReservationStatus.Rezerv)
                    {
                        <form method="post" action="/rezervasyonlar/confirm"><AntiforgeryToken /><input type="hidden" name="id" value="@r.Id" /><button class="link">Onayla</button></form>
                    }
                    @if (r.Durum is ReservationStatus.Rezerv or ReservationStatus.Onayli)
                    {
                        <form method="post" action="/rezervasyonlar/convert"><AntiforgeryToken /><input type="hidden" name="id" value="@r.Id" /><button class="link">Kiraya Çevir</button></form>
                        <form method="post" action="/rezervasyonlar/cancel" onsubmit="return confirm('İptal edilsin mi?')"><AntiforgeryToken /><input type="hidden" name="id" value="@r.Id" /><button class="link danger">İptal</button></form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<Reservation> _list = [];
    private IReadOnlyList<Customer> _customers = [];
    private IReadOnlyList<Vehicle> _vehicles = [];
    private IReadOnlyList<Location> _locations = [];
    private IReadOnlyList<ReservationSource> _kaynaklar = [];
    private Dictionary<Guid, string> _custMap = new();
    private Dictionary<Guid, string> _vehMap = new();
    private readonly string _defBas = DateTime.Now.ToString("yyyy-MM-ddT09:00");
    private readonly string _defBit = DateTime.Now.AddDays(3).ToString("yyyy-MM-ddT09:00");

    protected override async Task OnInitializedAsync()
    {
        _list = await Reservations.ListAsync();
        _customers = await Customers.ListAsync();
        _vehicles = await Vehicles.ListAsync();
        _locations = await Locations.ListActiveAsync();
        _kaynaklar = await Kaynaklar.ListActiveAsync();
        _custMap = _customers.ToDictionary(c => c.Id, c => c.DisplayName);
        _vehMap = _vehicles.ToDictionary(v => v.Id, v => v.Plaka);
    }

    private string Cust(Guid id) => _custMap.GetValueOrDefault(id, "—");
    private string Veh(Guid id) => _vehMap.GetValueOrDefault(id, "—");
}
