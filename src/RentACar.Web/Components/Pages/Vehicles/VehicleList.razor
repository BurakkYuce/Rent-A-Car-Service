@page "/vehicles"
@attribute [Authorize]
@inject VehicleService Vehicles
@inject VehicleGroupService AracGruplari

<PageTitle>Araçlar — TürevRent</PageTitle>

<h1>Araçlar</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_page.Total == 0)">
    <summary>+ Yeni Araç</summary>
    <form method="post" action="/vehicles/create" class="grid-form">
        <label>Plaka<input name="plaka" required /></label>
        <label>Marka<input name="marka" /></label>
        <label>Grup<input name="grup" list="arac-grup-list" placeholder="Tanımlı gruptan seç veya yaz" /></label>
        <label>Şube<input name="sube" /></label>
        <label>Durum
            <select name="durum">
                @foreach (var s in Enum.GetValues<VehicleStatus>())
                {
                    <option value="@s">@s</option>
                }
            </select>
        </label>
        <label>KM<input name="km" type="number" value="0" /></label>
        <label>Yakıt
            <select name="yakit">
                @foreach (var f in Enum.GetValues<FuelType>())
                {
                    <option value="@f">@f</option>
                }
            </select>
        </label>
        <button type="submit">Kaydet</button>
    </form>
</details>

<datalist id="arac-grup-list">
    @foreach (var g in _gruplar)
    {
        <option value="@g.Ad">@g.Kod</option>
    }
</datalist>

<form method="get" class="filter-bar">
    <input name="q" value="@Q" placeholder="Plaka / marka ara" />
    <input name="grup" value="@Grup" list="arac-grup-list" placeholder="Grup" />
    <select name="durum">
        <option value="">Durum (tümü)</option>
        @foreach (var s in Enum.GetValues<VehicleStatus>())
        {
            <option value="@s" selected="@(Durum == s.ToString())">@s</option>
        }
    </select>
    <button type="submit">Filtrele</button>
    @if (!string.IsNullOrEmpty(Q) || !string.IsNullOrEmpty(Grup) || !string.IsNullOrEmpty(Durum))
    {
        <a href="/vehicles" class="link">Temizle</a>
    }
</form>

<table class="grid">
    <thead>
        <tr>
            <th>Plaka</th><th>Marka</th><th>Grup</th><th>Şube</th>
            <th>Durum</th><th>KM</th><th>Yakıt</th><th></th>
        </tr>
    </thead>
    <tbody>
        @if (_page.Items.Count == 0)
        {
            <tr><td colspan="8" class="muted">Kayıtlı araç yok.</td></tr>
        }
        @foreach (var v in _page.Items)
        {
            <tr>
                <td><a href="/vehicles/@v.Id">@v.Plaka</a></td>
                <td>@v.Marka</td>
                <td>@v.Grup</td>
                <td>@v.Sube</td>
                <td>@v.Durum</td>
                <td>@v.Km</td>
                <td>@v.Yakit</td>
                <td>
                    <a href="/araclar/@v.Id" class="link">Detay</a>
                    <form method="post" action="/vehicles/delete" onsubmit="return confirm('Silinsin mi?')">
                        <input type="hidden" name="id" value="@v.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (_page.TotalPages > 1)
{
    <nav class="pager">
        @if (_page.HasPrev) { <a href="@PageUrl(_page.Page - 1)">← Önceki</a> }
        <span class="muted">Sayfa @_page.Page / @_page.TotalPages (@_page.Total kayıt)</span>
        @if (_page.HasNext) { <a href="@PageUrl(_page.Page + 1)">Sonraki →</a> }
    </nav>
}

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }
    [SupplyParameterFromQuery(Name = "q")] public string? Q { get; set; }
    [SupplyParameterFromQuery(Name = "grup")] public string? Grup { get; set; }
    [SupplyParameterFromQuery(Name = "durum")] public string? Durum { get; set; }
    [SupplyParameterFromQuery(Name = "page")] public int? Page { get; set; }

    private PagedResult<Vehicle> _page = new([], 0, 1, 20);
    private IReadOnlyList<VehicleGroup> _gruplar = [];

    protected override async Task OnInitializedAsync()
    {
        var filter = new VehicleFilter
        {
            Query = Q, Grup = Grup, Page = Page ?? 1,
            Durum = Enum.TryParse<VehicleStatus>(Durum, out var d) ? d : null
        };
        _page = await Vehicles.SearchAsync(filter);
        _gruplar = await AracGruplari.ListActiveAsync();
    }

    private string PageUrl(int p)
    {
        var qs = new List<string> { $"page={p}" };
        if (!string.IsNullOrEmpty(Q)) qs.Add($"q={Uri.EscapeDataString(Q)}");
        if (!string.IsNullOrEmpty(Grup)) qs.Add($"grup={Uri.EscapeDataString(Grup)}");
        if (!string.IsNullOrEmpty(Durum)) qs.Add($"durum={Durum}");
        return "/vehicles?" + string.Join("&", qs);
    }
}
