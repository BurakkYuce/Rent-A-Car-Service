@page "/vehicles/{Id:guid}"
@attribute [Authorize]
@inject VehicleService Vehicles
@inject BrandService Markalar
@inject VehicleGroupService AracGruplari
@inject NavigationManager Nav

<PageTitle>Araç Düzenle — TürevRent</PageTitle>

<h1>Araç Düzenle</h1>

@if (_vehicle is null)
{
    <p class="error">Araç bulunamadı.</p>
    <a href="/vehicles">← Listeye dön</a>
}
else
{
    @if (!string.IsNullOrEmpty(Hata))
    {
        <p class="error">@Hata</p>
    }

    <form method="post" action="/vehicles/update" class="grid-form"><AntiforgeryToken />
        <input type="hidden" name="id" value="@_vehicle.Id" />
        <label>Plaka<input name="plaka" value="@_vehicle.Plaka" required /></label>
        <label>Marka<input name="marka" value="@_vehicle.Marka" list="marka-list" placeholder="Tanımlı markadan seç veya yaz" /></label>
        <datalist id="marka-list">
            @foreach (var m in _markalar) { <option value="@m.Ad">@m.Kod</option> }
        </datalist>
        <label>Grup<input name="grup" value="@_vehicle.Grup" /></label>
        <label>Marka<input name="marka" value="@_vehicle.Marka" /></label>
        <label>Grup
            <input name="grup" value="@_vehicle.Grup" list="arac-grup-list" placeholder="Tanımlı gruptan seç veya yaz" />
        </label>
        <datalist id="arac-grup-list">
            @foreach (var g in _gruplar)
            {
                <option value="@g.Ad">@g.Kod</option>
            }
        </datalist>
        <label>Marka<input name="marka" value="@_vehicle.Marka" /></label>
        <label>Tip<input name="tip" value="@_vehicle.Tip" /></label>
        <label>Grup<input name="grup" value="@_vehicle.Grup" /></label>
        <label>Segment<input name="segment" value="@_vehicle.Segment" /></label>
        <label>SIPP<input name="sipp" value="@_vehicle.Sipp" maxlength="4" placeholder="CDMD" /></label>
        <label>Renk<input name="renk" value="@_vehicle.Renk" /></label>
        <label>Model Yılı<input name="modelYili" type="number" value="@_vehicle.ModelYili" /></label>
        <label>Vites
            <select name="vites">
                <option value="">—</option>
                @foreach (var vt in Enum.GetValues<Vites>())
                {
                    <option value="@vt" selected="@(_vehicle.Vites == vt)">@vt</option>
                }
            </select>
        </label>
        <label>Şasi No<input name="sasiNo" value="@_vehicle.SasiNo" /></label>
        <label>Motor No<input name="motorNo" value="@_vehicle.MotorNo" /></label>
        <label>Şube<input name="sube" value="@_vehicle.Sube" /></label>
        <label>Durum
            <select name="durum">
                @foreach (var s in Enum.GetValues<VehicleStatus>())
                {
                    <option value="@s" selected="@(s == _vehicle.Durum)">@s</option>
                }
            </select>
        </label>
        <label>Filo Status
            <select name="filoDurum">
                <option value="">—</option>
                @foreach (var fs in Enum.GetValues<FiloStatus>())
                {
                    <option value="@fs" selected="@(_vehicle.FiloDurum == fs)">@fs</option>
                }
            </select>
        </label>
        <label>KM<input name="km" type="number" value="@_vehicle.Km" /></label>
        <label>Yakıt
            <select name="yakit">
                @foreach (var f in Enum.GetValues<FuelType>())
                {
                    <option value="@f" selected="@(f == _vehicle.Yakit)">@f</option>
                }
            </select>
        </label>
        <label>Araç Sahibi<input name="aracSahibi" value="@_vehicle.AracSahibi" /></label>
        <label>Motor Gücü (HP)<input name="motorGucu" type="number" min="0" value="@_vehicle.MotorGucu" /></label>
        <label>Silindir Hacmi (cc)<input name="silindirHacmi" type="number" min="0" value="@_vehicle.SilindirHacmi" /></label>
        <label>Ruhsat No<input name="ruhsatNo" value="@_vehicle.RuhsatNo" /></label>
        <label>Tescil Tarihi<input name="tescilTarihi" type="date" value="@(_vehicle.TescilTarihi?.ToString("yyyy-MM-dd"))" /></label>
        <label>Alım Bedeli<input name="alimBedeli" type="number" step="0.01" min="0" value="@_vehicle.AlimBedeli" /></label>
        <label>Alım Tarihi<input name="alimTarihi" type="date" value="@(_vehicle.AlimTarihi?.ToString("yyyy-MM-dd"))" /></label>
        <label>Alış Vergisiz<input name="alisVergisiz" type="number" step="0.01" min="0" value="@_vehicle.AlisVergisiz" /></label>
        <label>Alış ÖTV<input name="alisOtv" type="number" step="0.01" min="0" value="@_vehicle.AlisOtv" /></label>
        <label>Alış KDV<input name="alisKdv" type="number" step="0.01" min="0" value="@_vehicle.AlisKdv" /></label>
        <label>Aylık Maliyet<input name="aylikMaliyet" type="number" step="0.01" min="0" value="@_vehicle.AylikMaliyet" /></label>
        <label>Filo Yön. Maliyeti<input name="filoYonetimMaliyeti" type="number" step="0.01" min="0" value="@_vehicle.FiloYonetimMaliyeti" /></label>
        <label>2.El Değer<input name="ikinciElDeger" type="number" step="0.01" min="0" value="@_vehicle.IkinciElDeger" /></label>
        <label>Filo Giriş<input name="filoGirisTarih" type="date" value="@(_vehicle.FiloGirisTarih?.ToString("yyyy-MM-dd"))" /></label>
        <label>Filo Çıkış<input name="filoCikisTarih" type="date" value="@(_vehicle.FiloCikisTarih?.ToString("yyyy-MM-dd"))" /></label>
        <label>Özel Kod 1<input name="ozelKod1" value="@_vehicle.OzelKod1" /></label>
        <label>Özel Kod 2<input name="ozelKod2" value="@_vehicle.OzelKod2" /></label>
        <label>Özel Kod 3<input name="ozelKod3" value="@_vehicle.OzelKod3" /></label>
        <label>Özel Kod 4<input name="ozelKod4" value="@_vehicle.OzelKod4" /></label>
        <label>Özel Kod 5<input name="ozelKod5" value="@_vehicle.OzelKod5" /></label>
        <button type="submit">Güncelle</button>
        <a href="/vehicles" class="link">İptal</a>
    </form>
}

@code {
    [Parameter] public Guid Id { get; set; }

    [SupplyParameterFromQuery(Name = "hata")]
    public string? Hata { get; set; }

    private Vehicle? _vehicle;
    private IReadOnlyList<Brand> _markalar = [];
    private IReadOnlyList<VehicleGroup> _gruplar = [];

    protected override async Task OnInitializedAsync()
    {
        _vehicle = await Vehicles.GetAsync(Id);
        _markalar = await Markalar.ListActiveAsync();
        _gruplar = await AracGruplari.ListActiveAsync();
    }
}
