@page "/arac-siparis"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@using RentACar.Application.AracSiparisleri
@using RentACar.Domain.Enums
@inject AracSiparisService Siparisler

<PageTitle>Araç Sipariş / Tedarik — TürevRent</PageTitle>

<h1>Araç Sipariş / Tedarik</h1>
<p class="muted small">Tedarikçiden araç siparişi takibi (FiloStatus: Sipariş). Defter postlamaz; teslim/satınalma
    faturalama ayrı.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details>
    <summary>Yeni Sipariş</summary>
    <form method="post" action="/arac-siparis/create" class="grid-form"><AntiforgeryToken />
        <label>Tedarikçi<input name="tedarikci" required /></label>
        <label>Sipariş Tarihi<input name="siparisTarihi" type="date" /></label>
        <label>Beklenen Teslim<input name="beklenenTeslim" type="date" /></label>
        <label>Marka<input name="marka" /></label>
        <label>Tip<input name="tip" /></label>
        <label>Grup<input name="grup" /></label>
        <label>Adet<input name="adet" type="number" min="1" value="1" required /></label>
        <label>Birim Fiyat<input name="birimFiyat" type="number" step="0.01" min="0" /></label>
        <label>Açıklama<input name="aciklama" /></label>
        <button type="submit">Kaydet</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>No</th><th>Tedarikçi</th><th>Araç</th><th class="num">Adet</th><th class="num">Birim</th><th class="num">Toplam</th><th>Sipariş</th><th>Beklenen</th><th>Durum</th><th></th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="10" class="muted">Sipariş yok.</td></tr>
        }
        @foreach (var s in _list)
        {
            <tr>
                <td>@s.No</td>
                <td>@s.Tedarikci</td>
                <td>@($"{s.Marka} {s.Tip} {s.Grup}".Trim())</td>
                <td class="num">@s.Adet</td>
                <td class="num">@s.BirimFiyat.ToString("N2")</td>
                <td class="num">@((s.Adet * s.BirimFiyat).ToString("N2")) @s.Currency</td>
                <td>@s.SiparisTarihi.ToString("yyyy-MM-dd")</td>
                <td>@(s.BeklenenTeslim?.ToString("yyyy-MM-dd") ?? "—")</td>
                <td>@s.Durum</td>
                <td>
                    @if (s.Durum == SiparisDurum.Bekliyor)
                    {
                        <form method="post" action="/arac-siparis/onayla" style="display:inline"><AntiforgeryToken /><input type="hidden" name="id" value="@s.Id" /><button type="submit">Onayla</button></form>
                        <form method="post" action="/arac-siparis/iptal" style="display:inline"><AntiforgeryToken /><input type="hidden" name="id" value="@s.Id" /><button type="submit" class="btn-secondary">İptal</button></form>
                    }
                    else if (s.Durum == SiparisDurum.Onaylandi)
                    {
                        <form method="post" action="/arac-siparis/teslim-al" style="display:inline"><AntiforgeryToken /><input type="hidden" name="id" value="@s.Id" /><button type="submit">Teslim Al</button></form>
                        <form method="post" action="/arac-siparis/iptal" style="display:inline"><AntiforgeryToken /><input type="hidden" name="id" value="@s.Id" /><button type="submit" class="btn-secondary">İptal</button></form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<AracSiparis> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await Siparisler.ListAsync();
}
