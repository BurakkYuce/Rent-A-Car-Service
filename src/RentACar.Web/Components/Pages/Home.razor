@page "/"
@attribute [Authorize]
@inject VehicleService Vehicles
@inject CustomerService Customers
@inject RentalService Rentals
@inject ReservationService Reservations
@inject VadeService Vade
@inject DashboardService Dashboard

<PageTitle>Panel — TürevRent</PageTitle>

<h1>Panel</h1>

<div class="cards">
    <div class="card">
        <div class="card-num">@_counts.Total</div>
        <div class="card-label">Toplam Araç</div>
    </div>
    <div class="card">
        <div class="card-num">@_counts.Musait</div>
        <div class="card-label">Müsait</div>
    </div>
    <div class="card">
        <div class="card-num">@_aktifKira</div>
        <div class="card-label">Aktif Kira</div>
    </div>
    <div class="card">
        <div class="card-num">@_bugunCikis</div>
        <div class="card-label">Bugün Çıkış</div>
    </div>
    <div class="card">
        <div class="card-num">@_bugunDonus</div>
        <div class="card-label">Bugün Dönüş</div>
    </div>
    <div class="card">
        <div class="card-num">@_cariCount</div>
        <div class="card-label">Cari</div>
    </div>
</div>

@* Finans özeti (roadmap D3) — yalnız mali yetkili roller (kasa/banka/açık bakiye hassas). *@
<AuthorizeView Roles="Admin,Yonetici,Muhasebe" Context="finCtx">
    <div class="cards">
        <div class="card">
            <div class="card-num">@_dash.KasaBakiye.ToString("N2")</div>
            <div class="card-label">Kasa Bakiye</div>
        </div>
        <div class="card">
            <div class="card-num">@_dash.BankaBakiye.ToString("N2")</div>
            <div class="card-label">Banka Bakiye</div>
        </div>
        <div class="card">
            <div class="card-num">@_dash.AcikBakiye.ToString("N2")</div>
            <div class="card-label">Açık Bakiye (fatura−tahsilat)</div>
        </div>
        <div class="card">
            <div class="card-num">@_dash.BugunTahsilatTutar.ToString("N2")</div>
            <div class="card-label">Bugün Tahsilat (@_dash.BugunTahsilatAdet adet)</div>
        </div>
    </div>
</AuthorizeView>

@if (_gecmis + _yakin > 0)
{
    <div class="vade-alert">
        ⚠️ <strong>Vade uyarısı:</strong>
        @if (_gecmis > 0) { <span class="badge danger">@_gecmis geçmiş</span> }
        @if (_yakin > 0) { <span class="badge warn">@_yakin yaklaşan (≤30 gün)</span> }
        <a href="/vade">Vade panosu →</a>
    </div>
}

<p>
    <a href="/vehicles">Araçlar →</a> &nbsp;
    <a href="/cariler">Cariler →</a> &nbsp;
    <a href="/rezervasyonlar">Rezervasyonlar →</a> &nbsp;
    <a href="/kiralar">Kiralar →</a> &nbsp;
    <a href="/giderler">Giderler →</a>
</p>

@code {
    private (int Total, int Musait, int Serviste) _counts;
    private int _cariCount;
    private int _aktifKira;
    private int _bugunCikis;
    private int _bugunDonus;
    private int _gecmis;
    private int _yakin;
    private DashboardDto _dash = new(0, 0, 0, 0, 0, 0, 0, 0m, 0m, 0m, 0m);

    protected override async Task OnInitializedAsync()
    {
        _dash = await Dashboard.GetAsync(DateTimeOffset.UtcNow);
        var list = await Vehicles.ListAsync();
        _counts = (
            list.Count,
            list.Count(v => v.Durum == VehicleStatus.Musait),
            list.Count(v => v.Durum == VehicleStatus.Serviste));
        _cariCount = (await Customers.ListAsync()).Count;

        var rentals = await Rentals.ListAsync();
        _aktifKira = rentals.Count(r => r.Durum == RentalStatus.Kirada);

        var bugun = DateTimeOffset.Now.Date;
        // Bugün dönüşü planlanan aktif kiralar (bitiş tarihi bugün).
        _bugunDonus = rentals.Count(r => r.Durum == RentalStatus.Kirada && r.BitTar.LocalDateTime.Date == bugun);
        // Bugün çıkışı planlanan rezervasyonlar (henüz iptal/kiraya çevrilmemiş, başlangıç bugün).
        var rezervler = await Reservations.ListAsync();
        _bugunCikis = rezervler.Count(r =>
            (r.Durum == ReservationStatus.Rezerv || r.Durum == ReservationStatus.Onayli)
            && r.BasTar.LocalDateTime.Date == bugun);

        var warnings = await Vade.GetWarningsAsync();
        _gecmis = warnings.Count(w => w.Bucket == VadeBucket.Gecmis);
        _yakin = warnings.Count(w => w.Bucket != VadeBucket.Gecmis);
    }
}
