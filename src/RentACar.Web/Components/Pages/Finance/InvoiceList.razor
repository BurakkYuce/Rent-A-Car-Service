@page "/faturalar"
@attribute [Authorize(Roles = "Admin,Yonetici,Muhasebe")]
@inject InvoiceService Invoices
@inject CustomerService Customers

<PageTitle>Faturalar — TürevRent</PageTitle>

<h1>Faturalar</h1>

<table class="grid">
    <thead><tr><th>No</th><th>Tarih</th><th>Müşteri</th><th>Net</th><th>KDV</th><th>Toplam</th><th>Durum</th><th></th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="8" class="muted">Fatura yok.</td></tr>
        }
        @foreach (var i in _list)
        {
            <tr>
                <td>@i.No</td>
                <td>@i.Tarih.LocalDateTime.ToString("dd.MM.yyyy")</td>
                <td>@CustName(i.CariId)</td>
                <td>@i.NetTutar.ToString("N2")</td>
                <td>@i.KdvTutar.ToString("N2")</td>
                <td>@i.GenelToplam.ToString("N2")</td>
                <td>@i.Durum</td>
                <td><a href="/faturalar/@i.Id/yazdir" class="link">Yazdır</a></td>
            </tr>
        }
    </tbody>
</table>

<h2>Manuel Fatura</h2>
<p class="muted small">Kiradan bağımsız serbest fatura (Borç Cari / Alacak Gelir+KDV, dengeli; dönem kilidine tabi).</p>
<form method="post" class="grid-form">
    <AntiforgeryToken />
    <input type="hidden" name="islemAnahtari" value="@_token" />@* çift-submit idempotency *@
    <label>Cari
        <select name="cariId" required>
            <option value="">—</option>
            @foreach (var c in _custMap)
            {
                <option value="@c.Key">@c.Value</option>
            }
        </select>
    </label>
    <label>Net Tutar<input name="netTutar" type="number" step="0.01" min="0" required /></label>
    <label>KDV Oranı<input name="kdvOrani" type="number" step="0.01" min="0" value="0.20" /></label>
    <label>Tarih<input name="tarih" type="date" /></label>
    <label>Vade<input name="vadeTarihi" type="date" /></label>
    <label>Açıklama<input name="aciklama" /></label>
    <button type="submit" formaction="/finans/fatura-manuel">Manuel Fatura Kes</button>
</form>

@code {
    private IReadOnlyList<Invoice> _list = [];
    private Dictionary<Guid, string> _custMap = new();
    private readonly Guid _token = Guid.NewGuid(); // manuel fatura çift-submit idempotency token

    protected override async Task OnInitializedAsync()
    {
        _list = await Invoices.ListAsync();
        _custMap = (await Customers.ListAsync()).ToDictionary(c => c.Id, c => c.DisplayName);
    }

    private string CustName(Guid id) => _custMap.TryGetValue(id, out var n) ? n : "—";
}
