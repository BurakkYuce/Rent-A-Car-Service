@page "/kasa"
@attribute [Authorize(Roles = "Admin,Yonetici,Muhasebe")]
@inject ReportService Reports
@inject CashService Cash
@inject CustomerService Customers

<PageTitle>Kasa / Banka — TürevRent</PageTitle>

<h1>Kasa / Banka</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<div class="cards">
    <div class="card">
        <div class="card-num @(_summary.KasaBakiye < 0 ? "neg" : "pos")">@_summary.KasaBakiye.ToString("N2")</div>
        <div class="card-label">Kasa Bakiye ₺</div>
    </div>
    <div class="card">
        <div class="card-num @(_summary.BankaBakiye < 0 ? "neg" : "pos")">@_summary.BankaBakiye.ToString("N2")</div>
        <div class="card-label">Banka Bakiye ₺</div>
    </div>
    <div class="card">
        <div class="card-num pos">@_summary.KasaGiris.ToString("N2")</div>
        <div class="card-label">Kasa Giriş ₺</div>
    </div>
    <div class="card">
        <div class="card-num pos">@_summary.BankaGiris.ToString("N2")</div>
        <div class="card-label">Banka Giriş ₺</div>
    </div>
</div>

<details class="new-vehicle">
    <summary>↔ Virman (Kasa ↔ Banka)</summary>
    <form method="post" action="/finans/virman" class="grid-form"><AntiforgeryToken />
        <label>Kaynak
            <select name="kaynak"><option>Kasa</option><option>Banka</option></select>
        </label>
        <label>Hedef
            <select name="hedef"><option>Banka</option><option>Kasa</option></select>
        </label>
        <label>Tutar<input name="tutar" type="number" step="0.01" required /></label>
        <label>Açıklama<input name="aciklama" /></label>
        <button type="submit">Aktar</button>
    </form>
</details>

<h2>Son İşlemler</h2>
<table class="grid">
    <thead>
        <tr><th>Tarih</th><th>No</th><th>Tip</th><th>Hesap</th><th>Cari</th><th>Tutar</th><th>Açıklama</th></tr>
    </thead>
    <tbody>
        @if (_txns.Count == 0)
        {
            <tr><td colspan="7" class="muted">İşlem yok.</td></tr>
        }
        @foreach (var t in _txns)
        {
            <tr>
                <td>@t.Tarih.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                <td class="mono">@t.No</td>
                <td>
                    @if (t.TersKayitMi) { <span class="badge warn">Ters</span> }
                    @(t.Tip == CashTransactionType.Odeme ? "Ödeme" : "Tahsilat")
                </td>
                <td>@t.KarsiHesap</td>
                <td>
                    @if (_adlar.TryGetValue(t.CariId, out var ad))
                    {
                        <a href="/cariler/@t.CariId/ekstre">@ad</a>
                    }
                    else { <span class="muted">—</span> }
                </td>
                <td>@t.Amount.Amount.ToString("N2") @t.Amount.Currency</td>
                <td>@t.Aciklama</td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private CashboxSummaryDto _summary = new(0, 0, 0, 0, 0, 0);
    private IReadOnlyList<CashTransaction> _txns = [];
    private Dictionary<Guid, string> _adlar = new();

    protected override async Task OnInitializedAsync()
    {
        _summary = await Reports.GetKasaBankaSummaryAsync();
        var all = await Cash.ListAsync();
        _txns = all.Take(50).ToList();
        _adlar = (await Customers.ListAsync()).ToDictionary(c => c.Id, c => c.DisplayName);
    }
}
