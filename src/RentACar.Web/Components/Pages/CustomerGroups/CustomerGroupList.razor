@page "/musteri-gruplari"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@inject CustomerGroupService MusteriGruplari

<PageTitle>Müşteri Grupları — TürevRent</PageTitle>

<h1>Müşteri Grubu Tanımları</h1>
<p class="muted small">Carilerin sınıflandırma gruplarının sözlüğü (ör. "Bireysel", "Kurumsal",
    "Acente", "Filo"). Cari formundaki Grup açılır listesini besler.</p>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<details class="new-vehicle" open="@(_list.Count == 0)">
    <summary>+ Yeni Müşteri Grubu</summary>
    <form method="post" action="/musteri-gruplari/create" class="grid-form">
        <label>Kod<input name="kod" required placeholder="KURUMSAL" /></label>
        <label>Ad<input name="ad" required placeholder="Kurumsal" /></label>
        <button type="submit">Oluştur</button>
    </form>
</details>

<table class="grid">
    <thead><tr><th>Kod</th><th>Ad</th><th>Durum</th><th>İşlem</th></tr></thead>
    <tbody>
        @if (_list.Count == 0)
        {
            <tr><td colspan="4" class="muted">Müşteri grubu tanımlı değil.</td></tr>
        }
        @foreach (var g in _list)
        {
            <tr>
                <td class="mono">@g.Kod</td>
                <td>@g.Ad</td>
                <td>@(g.Aktif ? "Aktif" : "Pasif")</td>
                <td>
                    <details>
                        <summary class="link">Düzenle</summary>
                        <form method="post" action="/musteri-gruplari/update" class="grid-form">
                            <input type="hidden" name="id" value="@g.Id" />
                            <label>Kod<input name="kod" value="@g.Kod" required /></label>
                            <label>Ad<input name="ad" value="@g.Ad" required /></label>
                            <label>Durum
                                <select name="aktif">
                                    <option value="true" selected="@g.Aktif">Aktif</option>
                                    <option value="false" selected="@(!g.Aktif)">Pasif</option>
                                </select>
                            </label>
                            <button type="submit">Kaydet</button>
                        </form>
                    </details>
                    <form method="post" action="/musteri-gruplari/delete" onsubmit="return confirm('Müşteri grubu silinsin mi?')">
                        <input type="hidden" name="id" value="@g.Id" />
                        <button type="submit" class="link danger">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [SupplyParameterFromQuery(Name = "hata")] public string? Hata { get; set; }

    private IReadOnlyList<CustomerGroup> _list = [];

    protected override async Task OnInitializedAsync()
        => _list = await MusteriGruplari.ListAsync();
}
