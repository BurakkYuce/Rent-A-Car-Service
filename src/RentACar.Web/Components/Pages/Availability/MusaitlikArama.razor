@page "/musaitlik"
@attribute [Authorize(Roles = "Admin,Yonetici,Operator")]
@using RentACar.Application.Availability
@using RentACar.Application.Pricing
@inject AvailabilityService Availability
@inject RentalQuoteEngine Quotes

<PageTitle>Müsait Araç Ara — TürevRent</PageTitle>

<h1>Müsait Araç Ara</h1>

@if (!string.IsNullOrEmpty(Hata))
{
    <p class="error">@Hata</p>
}

<form method="get" class="grid-form">
    <label>Başlangıç<input name="from" type="date" value="@From" required /></label>
    <label>Bitiş<input name="to" type="date" value="@To" required /></label>
    <label>Grup<input name="grup" value="@Grup" placeholder="(tümü)" /></label>
    <label>Şube<input name="sube" value="@Sube" placeholder="(tümü)" /></label>
    <button type="submit">Ara</button>
</form>

@if (_searched)
{
    <p class="muted">@From – @To arası @_list.Count müsait araç.</p>
    <table class="grid">
        <thead><tr><th>Plaka</th><th>Marka</th><th>Grup</th><th>Şube</th><th class="num">Günlük</th><th class="num">Toplam</th><th>Döviz</th><th></th></tr></thead>
        <tbody>
            @if (_list.Count == 0)
            {
                <tr><td colspan="8" class="muted">Bu aralıkta müsait araç yok.</td></tr>
            }
            @foreach (var v in _list)
            {
                var f = Fiyat(v.Grup);
                <tr>
                    <td>@v.Plaka</td>
                    <td>@v.Marka</td>
                    <td>@v.Grup</td>
                    <td>@v.Sube</td>
                    <td class="num">@(f is null ? "—" : f.Value.Gunluk.ToString("N2"))</td>
                    <td class="num">@(f is null ? "—" : f.Value.Toplam.ToString("N2"))</td>
                    <td>@(f?.Para)</td>
                    <td><a href="/rezervasyonlar">Rezervasyon →</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [SupplyParameterFromQuery(Name = "from")] public string? From { get; set; }
    [SupplyParameterFromQuery(Name = "to")] public string? To { get; set; }
    [SupplyParameterFromQuery(Name = "grup")] public string? Grup { get; set; }
    [SupplyParameterFromQuery(Name = "sube")] public string? Sube { get; set; }

    private IReadOnlyList<Vehicle> _list = [];
    private readonly Dictionary<string, (decimal Gunluk, decimal Toplam, string Para)> _fiyat = new(StringComparer.OrdinalIgnoreCase);
    private bool _searched;
    private string? Hata;

    private (decimal Gunluk, decimal Toplam, string Para)? Fiyat(string? grup)
        => grup is not null && _fiyat.TryGetValue(grup, out var f) ? f : null;

    protected override async Task OnInitializedAsync()
    {
        var from = ParseDate(From);
        var to = ParseDate(To);
        if (from is null || to is null) return; // ilk açılış: arama yok

        _searched = true;
        try
        {
            _list = await Availability.FindAvailableAsync(from.Value, to.Value, Grup, Sube);
            // roadmap G4: her müsait grup için fiyat motorundan teklif (kanal=null booking akışı).
            foreach (var grup in _list.Select(v => v.Grup)
                .Where(g => !string.IsNullOrWhiteSpace(g)).Distinct(StringComparer.OrdinalIgnoreCase))
            {
                try
                {
                    var q = await Quotes.QuoteAsync(new QuoteRequest
                    { AracGrupKod = grup!, BasTar = from.Value, BitTar = to.Value, Sube = Sube, SigortaUrunKodlari = [] });
                    _fiyat[grup!] = (q.GunlukUcret, q.GenelToplam, q.ParaBirimi);
                }
                catch (RentACar.Application.Common.ValidationException) { /* grup/tarih geçersiz → fiyat gösterilmez */ }
            }
        }
        catch (RentACar.Application.Common.ValidationException ex)
        {
            Hata = ex.Message;
            _searched = false;
        }
    }

    private static DateTimeOffset? ParseDate(string? s)
        => DateTimeOffset.TryParse(s, out var d) ? new DateTimeOffset(d.Date, TimeSpan.Zero) : null;
}
